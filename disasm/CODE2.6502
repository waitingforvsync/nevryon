\ ----- code &29E7..&2A02 -----
.draw_score
    \ Draw the 6-digit score at char-col 9, row &5F. Sets up the screen address then tail-falls into
    \ draw_score_digits_loop with X = 0.
    LDX #&09
    LDY #&5F
    JSR calc_screen_addr
    LDX #&00

.draw_score_digits_loop
    \ Iterate the 6-byte BCD score buffer, calling draw_score_digit per byte. Shared by draw_score
    \ and draw_high_score's render path.
    \
    \ Inputs:
    \ X = starting index (caller pre-sets to 0)
    \ Source buffer: hardwired to `score` here (compare draw_high_score which uses high_score). The
    \ two paths happen to share this loop body because both buffers are 6 bytes wide and laid out
    \ the same way.
    \ Current screen address: set up by caller (via calc_screen_addr).
    \
    \ Uses `scratch_28D3` to save X across the draw_score_digit call (X is overwritten by the
    \ digit-sprite selector). Loops until CPX #&06.
    LDA score,X
    STX scratch_28D3
    JSR draw_score_digit
    LDX scratch_28D3
    INX
    CPX #&06
    BNE draw_score_digits_loop
    RTS

\ ----- data &2A02..&2A08 -----
\ Score: 6-byte BCD buffer, most-significant digit first. Bytes 0..3 are the four upper display
\ digits (ten-thousands → tens of thousands → thousands → hundreds), byte 4 is the tens digit (which
\ is what add_score_x1/x10 actually increment), byte 5 is always 0 (the trailing '0' that appears on
\ screen — Nevryon awards score in multiples of 10). draw_score loops X=0..5 reading score,X.
\ add_score_x1 / add_score_x10 in CODE add zp_score_acc (or zp_score_acc×10) at byte 4 / byte 3 with
\ carry propagating upward through bytes 3..0.
.score
    EQUB &00, &00, &00, &00, &00, &00

\ ----- code &2A08..&2B9A -----
.draw_score_digit
    \ Draw one score digit at the current screen position.
    \
    \ Inputs: A = digit value (0..9), X = column offset.
    \ Selects gfx_digit_N via `&3A60 + 8*N` and plots a 4×8 sprite.
    STX scratch_28D3
    ASL A
    ASL A
    ASL A
    CLC
    ADC #&60
    STA sprite_src_lo
    LDA #&3A
    STA sprite_src_hi
    LDX #&01
    LDY #&08
    JMP sprite_plot_xy

.spawn_hazard_missile
    \ Try to spawn a new hazard missile in one of the two slots (hazard_missile_x[0..1] == &FF =
    \ free). Called from CODE's hazard_type_dispatch for hazard_type &06. Validates the firer's
    \ hazard_x is in [&08, &25] (on-screen), copies hazard_x + 2 / hazard_y into the missile slot,
    \ mirrors hazard_flip into hazard_missile_flip (controls vertical direction in
    \ step_hazard_missile), and sets hazard_missile_homing_dir from a player-X comparison: 1 if
    \ player_x + 3 >= missile_x (player to the right of the missile → home rightward), 0 otherwise
    \ (home leftward). Plays sfx_score_tick to mark the launch.
    \
    \ The missile sprite is `gfx_icon_missile_rocket` — a 4×6-px yellow-and-red rocket pointing
    \ vertically.
    LDA zp_get_ready_erase
    CMP #&02
    BNE L2A3E
    STX scratch_28D4
    LDX #&00
    LDA hazard_missile_x,X
    CMP #&FF
    BEQ L2A3F
    LDX #&01
    LDA hazard_missile_x,X
    CMP #&FF
    BEQ L2A3F
    LDX scratch_28D4
.L2A3E
    RTS
.L2A3F
    STX scratch_28D3
    LDX scratch_28D4
    LDA hazard_x,X
    CMP #&08
    BCC L2A9E
    CMP #&25
    BCS L2A9E
    CLC
    ADC #&02
    LDX scratch_28D3
    STA hazard_missile_x,X
    LDX scratch_28D4
    LDA hazard_flip,X
    CMP #&01
    BEQ L2A6F
    STA hazard_missile_flip
    LDA hazard_y,X
    SEC
    SBC #&18
    JMP L2A7B
.L2A6F
    LDX scratch_28D3
    STA hazard_missile_flip,X
    LDX scratch_28D4
    LDA hazard_y,X
.L2A7B
    LDX scratch_28D3
    STA hazard_missile_y,X
    LDA #&00
    STA hazard_missile_unused,X
    STA hazard_missile_homing_dir,X
    LDA zp_player_x
    CLC
    ADC #&03
    CMP hazard_missile_x,X
    BCS L2A96
    JMP L2A9B
.L2A96
    LDA #&01
    STA hazard_missile_homing_dir,X
.L2A9B
    JSR sfx_score_tick
.L2A9E
    LDX scratch_28D4
    RTS

.update_hazard_missiles
    \ Per-frame: step each of the 2 hazard missiles (slots 0 and 1) then collision-check each
    \ against the player. Inactive slots (hazard_missile_x == &FF) are skipped.
    LDX #&00
    LDA hazard_missile_x,X
    CMP #&FF
    BEQ L2AAE
    JSR step_hazard_missile
.L2AAE
    LDX #&01
    LDA hazard_missile_x,X
    CMP #&FF
    BEQ L2ABA
    JSR step_hazard_missile
.L2ABA
    LDX #&00
    JSR missile_player_collide
    LDX #&01
    JMP missile_player_collide

.step_hazard_missile
    \ Step one hazard missile (X = slot index 0..1). Erases the old 1×6 position with
    \ lev_erase_brush + &80, then advances:
    \ horizontally by hazard_missile_homing_dir (1 = INC X by 1, else DEC X by 2 — homes on the
    \ player)
    \ vertically by hazard_missile_flip (1 = Y+=2, else Y-=2)
    \
    \ Bounds-checks the new (X, Y) against the playfield; out-of-bounds → mark slot inactive. Plots
    \ gfx_icon_missile_rocket (4×6-px rocket) at the new position.
    STX scratch_28D3
    LDA hazard_missile_x,X
    LDY hazard_missile_y,X
    TAX
    JSR calc_screen_addr
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    LDX #&01
    LDY #&06
    JSR sprite_plot_xy
    LDX scratch_28D3
    LDA hazard_missile_homing_dir,X
    CMP #&01
    BEQ L2AF5
    DEC hazard_missile_x,X
    DEC hazard_missile_x,X
    JMP L2AF8
.L2AF5
    INC hazard_missile_x,X
.L2AF8
    LDA hazard_missile_x,X
    CMP #&03
    BCC L2B42
    CMP #&25
    BCS L2B42
    LDA hazard_missile_flip,X
    CMP #&01
    BEQ L2B1A
    SEC
    LDA hazard_missile_y,X
    SBC #&02
    STA hazard_missile_y,X
    CMP #&82
    BCC L2B42
    JMP L2B27
.L2B1A
    CLC
    LDA hazard_missile_y,X
    ADC #&02
    STA hazard_missile_y,X
    CMP #&C8
    BCS L2B42
.L2B27
    LDA hazard_missile_x,X
    LDY hazard_missile_y,X
    TAX
    JSR calc_screen_addr
    LDA #LO(gfx_icon_missile_rocket)
    STA sprite_src_lo
    LDA #HI(gfx_icon_missile_rocket)
    STA sprite_src_hi
    LDX #&01
    LDY #&06
    JMP sprite_plot_xy
.L2B42
    LDA #&FF
    STA hazard_missile_x,X
    RTS

.missile_player_collide
    \ Box-collision check between one hazard_missile slot and the player. On hit, jumps to the
    \ player-death path (lose_a_life via the CODE-side handler).
    STX scratch_28D3
    LDA hazard_missile_x,X
    STA zp_test_x
    LDA hazard_missile_y,X
    SEC
    SBC #&04
    STA zp_test_y
    LDA zp_player_x
    CMP zp_test_x
    BCS L2B99
    ADC #&06
    CMP zp_test_x
    BCC L2B99
    LDA zp_player_y
    CMP zp_test_y
    BCC L2B99
    SBC #&18
    CMP zp_test_y
    BCS L2B99
    LDY hazard_missile_y,X
    LDA hazard_missile_x,X
    TAX
    JSR calc_screen_addr
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    LDX #&01
    LDY #&06
    JSR sprite_plot_xy
    LDX scratch_28D3
    LDA #&FF
    STA hazard_missile_x,X
    JSR lose_a_life
    JSR sfx_explode
.L2B99
    RTS

\ ----- data &2B9A..&2BA4 -----
.hazard_missile_x
    EQUB &FF, &FF
.hazard_missile_y
    EQUB &EA, &EA
.hazard_missile_flip
    EQUB &EA, &EA
.hazard_missile_unused
    EQUB &EA, &EA
.hazard_missile_homing_dir
    EQUB &EA, &EA

\ ----- code &2BA4..&2E5A -----
.intro_get_ready
    \ Level-start GET READY! intro. Draws the score, plots 7 gfx_icon_lives_intro sprites at row &57
    \ col 8..&F, shutter-fades to a black star field, plays sfx_explode for drama, then loops 75
    \ frames updating starfield and blitting gfx_text_get_ready (split as two 8-col halves at cols
    \ 12 and 20) before erasing.
    JSR draw_score
    LDA #&08
    STA scratch_28D3
.L2BAC
    LDX scratch_28D3
    LDY #&57
    JSR calc_screen_addr
    LDA #LO(gfx_icon_lives_intro)
    STA sprite_src_lo
    LDA #HI(gfx_icon_lives_intro)
    STA sprite_src_hi
    LDX #&01
    LDY #&08
    JSR sprite_plot_xy
    INC scratch_28D3
    LDA scratch_28D3
    CMP #&0F
    BNE L2BAC
    JSR shutter_fade
    LDX #&00
    STX scratch_28D5
    JSR sfx_explode
.L2BDA
    LDX scratch_28D5
    INX
    STX scratch_28D5
    CPX #&4B
    BEQ L2C20
    JSR starfield_update
    LDX #&0C
    LDY #&C8
    JSR calc_screen_addr
    LDX #&08
    LDY #&10
    LDA #LO(gfx_text_get_ready)
    STA sprite_src_lo
    LDA #HI(gfx_text_get_ready)
    STA sprite_src_hi
    JSR sprite_plot_xy
    LDX #&14
    LDY #&C8
    JSR calc_screen_addr
    LDX #&08
    LDY #&10
    LDA #LO(gfx_text_get_ready + &80)
    STA sprite_src_lo
    LDA #HI(gfx_text_get_ready + &80)
    STA sprite_src_hi
    JSR sprite_plot_xy
    LDA #&13
    JSR OSBYTE
    JMP L2BDA
.L2C20
    LDX #&0C
    LDY #&C8
    JSR calc_screen_addr
    LDX #&08
    LDY #&10
