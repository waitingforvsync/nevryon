\ ----- code &28D7..&2973 -----
.force_pod_anim
death_seq_frame_counter = * + 1
    \ Per-subframe (from game_step's play_subframe): if force_pod_state == 1, animate the floating
    \ force-pod power-up — a chomping ball drawn at (force_pod_x, force_pod_y). Erases the previous
    \ frame with lev_erase_brush + &80 (2 byte-col × &0C lines), then plots one of 6 frames at
    \ gfx_ball_frame0..5 (each 2×&0C = &18 bytes).
    \
    \ Frame selection: inline multiply-by-&18 — `LDA #LO(gfx_ball_frame0 - &18); CLC; LDX
    \ force_pod_frame; loop ADC #&18 / DEX / BNE` — so frame N=1 gives &60 (= gfx_ball_frame0), N=2
    \ gives &78, ..., N=6 gives &D8. HI is hard-wired to &38.
    \
    \ After plot, force_pod_frame INCs (wraps 7→1). Also checks (a) OSBYTE &81 / -1 INKEY for any
    \ key press, and (b) a box-collision against the player ship — either condition dismisses the
    \ pod (jumps to L299F, presumably to collect or hide).
    LDA force_pod_state
    CMP #&01
    BEQ L28DF
    RTS
.L28DF
    LDX force_pod_x
    LDY force_pod_y
    JSR calc_screen_addr
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    LDX #&02
    LDY #&0C
    JSR sprite_plot_xy
    LDX #&9D
    LDA #&81
    LDY #&FF
    JSR OSBYTE
    CPY #&FF
    BNE L2909
    JMP L299F
.L2909
    LDA zp_player_x
    SEC
    SBC #&06
    CMP #&1E
    BCS L291A
    CMP force_pod_x
    BCC L291A
    JMP L299F
.L291A
    CLC
    ADC #&10
    CMP force_pod_x
    BCS L2925
    JMP L299F
.L2925
    LDA zp_player_y
    SEC
    SBC #&28
    CMP force_pod_y
    BCC L2932
    JMP L299F
.L2932
    LDA zp_player_y
    CLC
    ADC #&1E
    CMP force_pod_y
    BCS L293F
    JMP L299F
.L293F
    LDX force_pod_x
    LDY force_pod_y
    JSR calc_screen_addr
    LDA #LO(gfx_ball_frame0 - &18)
    CLC
    LDX force_pod_frame
.L294E
    ADC #&18
    DEX
    BNE L294E
    STA sprite_src_lo
    LDA #HI(gfx_ball_frame0 - &18)
    STA sprite_src_hi
    LDX #&02
    LDY #&0C
    JSR sprite_plot_xy
    INC force_pod_frame
    LDA force_pod_frame
    CMP #&07
    BNE L2971
    LDA #&01
    STA force_pod_frame
.L2971
    RTS

.force_pod_x
    BRK

