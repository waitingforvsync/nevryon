.sfx_fire
    \ Play 'fire' sound via OSWORD &07. Loads the param block at &2809 (ch=&0013 amp=2 pitch=&4B
    \ dur=1).
    LDA #&07
    LDX #&09
    LDY #&28
    JMP OSWORD

