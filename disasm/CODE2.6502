.draw_high_score
    \ Render the 6-digit high_score buffer onto the screen at (col &11, row &96). Loops X = 0..5
    \ reading high_score[X] and calls draw_score_digit per byte (same render style as draw_score,
    \ just from a different buffer at a different screen position). Called from the stage-clear /
    \ game-over UI.
    LDX #&11
    LDY #&96
    JSR calc_screen_addr
    LDX #&00
.L2E48
    LDA high_score,X
    STX scratch_28D3
    JSR draw_score_digit
    LDX scratch_28D3
    INX
    CPX #&06
    BNE L2E48
    RTS

\ ----- data &2E5A..&2E60 -----
\ High score: 6-byte BCD buffer, same layout as `score`. Initialised to all zero on disk. Compared
\ against `score` by check_new_high_score after each life lost and after each stage clear; if the
\ current score is higher, copied over byte-by-byte. Rendered by draw_high_score onto the
\ stage-clear screen.
.high_score
    EQUB &00, &00, &00, &00, &00, &00

\ ----- code &2E60..&2E8C -----
.check_new_high_score
    \ Compare current `score` against `high_score` byte-by-byte MSD-first. If the current score is
    \ strictly greater (any score byte > the matching high_score byte before equality runs out),
    \ copies all 6 bytes of score into high_score so subsequent draw_high_score calls show the new
    \ value.
    \
    \ Used at game-over / stage-clear to roll the leaderboard.
    LDX #&00
.L2E62
    LDA high_score,X
    CMP score,X
    BEQ L2E6F
    BCS L2E74
    JMP L2E75
.L2E6F
    INX
    CPX #&06
    BNE L2E62
.L2E74
    RTS
.L2E75
    LDX #&00
.L2E77
    LDA score,X
    STA high_score,X
    INX
    CPX #&06
    BNE L2E77
    RTS

.sfx_score_tick
    \ Beep that plays during the BONUS countdown roll-up (called from stage_clear_screen).
    LDA #&07
    LDX #&8C
    LDY #&2E
    JMP OSWORD

\ ----- data &2E8C..&2E94 -----
\ OSWORD &07 param block for sfx_score_tick: ch=&0012 amp=4 pitch=&64 dur=3
.sfx_score_tick_params
    EQUB &12, &00, &04, &00, &64, &00, &03, &00

\ ----- code &2E94..&2EF6 -----
.play_death_sequence
    \ Play the death sequence sound effects (a 3-tone descending pitch followed by a noise burst).
    LDA #&06
    NOP
    NOP
    NOP
    JSR shutter_fade
    JSR sfx_explode
    LDX #&00
    STX death_seq_frame_counter
.L2EA4
    LDX death_seq_frame_counter
    INX
    STX death_seq_frame_counter
    CPX #&C8
    BEQ L2EEA
    JSR starfield_update
    LDX #&0C
    LDY #&C8
    JSR calc_screen_addr
    LDX #&08
    LDY #&10
    LDA #LO(gfx_text_game)
    STA sprite_src_lo
    LDA #HI(gfx_text_game)
    STA sprite_src_hi
    JSR sprite_plot_xy
    LDX #&15
    LDY #&C8
    JSR calc_screen_addr
    LDX #&08
    LDY #&10
    LDA #LO(gfx_text_over)
    STA sprite_src_lo
    LDA #HI(gfx_text_over)
    STA sprite_src_hi
    JSR sprite_plot_xy
    LDA #&13
    JSR OSBYTE
    JMP L2EA4
.L2EEA
    JMP shutter_fade

.sfx_level_start
    \ Play 'level start / pickup' sound. Param block at &2EF6 (ch=&0011 amp=4 pitch=&FF dur=&0F).
    LDA #&07
    LDX #&F6
    LDY #&2E
    JMP OSWORD

\ ----- data &2EF6..&2EFF -----
.sfx_level_start_params
    EQUB &11, &00, &04, &00, &FF, &00, &0F, &00
.pad_2EFE
    \ Single &EA padding byte between the sfx_level_start OSWORD parameter block (&2EF6..&2EFD) and
    \ the next routine entry at &2EFF.
    EQUB &EA

\ ----- code &2EFF..&3041 -----
.intro_or_scoreboard
    \ Branch: if lives_left == 6 (fresh game, full lives) → ship_intro_anim; otherwise →
    \ draw_final_scoreboard. Called from main_init after the score restore.
    LDA lives_left
    CMP #&06
    BEQ ship_intro_anim
    JMP draw_final_scoreboard

.ship_intro_anim
    \ Plays the four-frame ship reveal animation (right-to-left): the player ship at
    \ lev_player_sprite is plotted progressively wider from col 5 → col 2 over four vsyncs.
    LDA #&00
    STA pad_2EFE
    JSR shutter_fade
    JSR ship_intro_frame_5
    JSR ship_intro_frame_4
    JSR ship_intro_frame_3
    JSR ship_intro_frame_2
    JMP L2F78

.ship_intro_frame_5
    JSR ship_intro_blit_setup
    LDA #&D8
    STA sprite_src_lo
    LDX #&01
    JMP sprite_plot_xy

.ship_intro_frame_4
    JSR ship_intro_blit_setup
    LDA #&C2
    STA sprite_src_lo
    LDX #&02
    JMP sprite_plot_xy

.ship_intro_frame_3
    JSR ship_intro_blit_setup
    LDA #&AC
    STA sprite_src_lo
    LDX #&03
    JMP sprite_plot_xy

.ship_intro_frame_2
    JSR ship_intro_blit_setup
    LDA #&96
    STA sprite_src_lo
    LDX #&04
    JMP sprite_plot_xy

.ship_intro_blit_setup
    \ Setup helper for ship_intro_frame_*: wait a frame, then calc_screen_addr at (0, &C8), set
    \ sprite_src_hi=&4E (LEVD1), Y=&16 (22 lines).
    JSR wait_one_frame
    LDX #&00
    LDY #&C8
    JSR calc_screen_addr
    LDA #&4E
    STA sprite_src_hi
    LDY #&16
    RTS

.wait_one_frame
    \ Run one frame: starfield_update + ~256*60 cycle delay + OSBYTE &13 (wait vsync).
    JSR starfield_update
    LDX #&3C
.L2F6B
    LDY #&FF
.L2F6D
    DEY
    BNE L2F6D
    DEX
    BNE L2F6B
    LDA #&13
    JMP OSBYTE
.L2F78
    LDA #&00
    STA zp_print_idx
.L2F7C
    JSR wait_one_frame
    LDX zp_print_idx
    LDY #&C8
    JSR calc_screen_addr
    LDX #&05
    LDY #&16
    LDA #LO(lev_player_sprite)
    STA sprite_src_lo
    LDA #HI(lev_player_sprite)
    STA sprite_src_hi
    JSR sprite_plot_xy
    INC zp_print_idx
    LDA zp_print_idx
    CMP #&04
    BCC L2FEB
    LDA zp_print_idx
    SEC
    SBC #&04
    TAX
    LDY #&C4
    JSR calc_screen_addr
    LDX #&04
    LDY #&10
    LDA #LO(gfx_muzzle_flash_frame0 + &10)
    STA sprite_src_lo
    LDA #HI(gfx_muzzle_flash_frame0 + &10)
    STA sprite_src_hi
    LDA pad_2EFE
    CMP #&01
    BNE L2FC4
    LDA #&C0
    STA sprite_src_lo
.L2FC4
    LDA pad_2EFE
    EOR #&01
    STA pad_2EFE
    JSR sprite_plot_xy
    LDA zp_print_idx
    SEC
    SBC #&05
    TAX
    LDY #&C4
    JSR calc_screen_addr
    LDX #&01
    LDY #&10
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    JSR sprite_plot_xy
.L2FEB
    LDA zp_print_idx
    CMP #&19
L2FF0            = * + 1
    BNE L2F7C
    LDA zp_print_idx
    SEC
    SBC #&04
    TAX
    LDY #&C4
    JSR calc_screen_addr
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    LDX #&04
    LDY #&10
    JSR sprite_plot_xy
    JSR wait_one_frame
    JSR wait_one_frame
    JSR wait_one_frame
    JSR wait_one_frame
    DEC zp_print_idx
.L301B
    JSR wait_one_frame
    LDX zp_print_idx
    LDY #&C8
    JSR calc_screen_addr
    LDX #&06
    LDY #&16
    LDA #LO(lev_player_sprite)
    STA sprite_src_lo
    LDA #HI(lev_player_sprite)
    STA sprite_src_hi
    JSR sprite_plot_xy
    DEC zp_print_idx
    LDA zp_print_idx
    CMP #&04
    BNE L301B
    INC zp_print_idx
    RTS

\ ----- data &3041..&30F8 -----
\ Starfield engine state — three parallel 61-byte arrays. Loop bound is X<60 (60 active stars; the
\ 61st slot in each array is unused). Mutated in place every frame by starfield_update in CODE.
.starfield_pos_lo
    EQUB &00, &D0, &18, &30, &48, &F0, &F0, &10
    EQUB &08, &38, &D0, &98, &68, &70, &68, &90
    EQUB &90, &F0, &08, &10, &C8, &10, &50
.L3058
    EQUB &E8, &28, &F0, &50, &90, &B0, &B0, &00
    EQUB &28, &08, &A0, &B8, &D8, &58, &F0, &B0
    EQUB &F8, &C8, &00, &B0, &68, &A0, &90, &80
    EQUB &F8, &68, &F0, &30, &F8, &10, &50, &B0
    EQUB &E8, &48, &E0, &E0, &F0, &40
.starfield_pos_hi
    EQUB &6C, &6A, &63, &5E, &66, &63, &63, &66
    EQUB &6A, &5F, &60, &5E, &5F, &6B, &68, &62
    EQUB &66, &6B, &63, &69, &61, &5E, &6B, &65
    EQUB &65, &69, &5F, &68, &66, &61, &61, &69
    EQUB &6A, &65, &69, &65, &5F, &6A, &67, &5F
    EQUB &62, &63, &63, &61, &5E, &61, &63, &6B
    EQUB &62, &62, &62, &5E, &66, &62, &62, &6B
    EQUB &5F, &6A, &6A, &67, &5F
.starfield_type
    EQUB &03, &03, &03, &03, &03, &03, &03, &03
    EQUB &03, &03, &03, &03, &03, &03, &03, &03
    EQUB &03, &03, &03, &03, &03, &02, &02, &02
    EQUB &02, &02, &02, &02, &02, &02, &02, &02
    EQUB &02, &02, &02, &02, &02, &02, &02, &02
    EQUB &02, &02, &02, &02, &02, &02, &02, &02
    EQUB &02, &02, &02, &02, &02, &02, &02, &02
    EQUB &02, &02, &02, &02, &02

\ ----- code &30F8..&31E9 -----
.save_score_to_loader
    \ Save current score and high-score to the loader persistence area at page &0CF3+. Called when
    \ handing off to the BASIC loader between stages.
    \
    \ Effects: writes loader_lives_save = lives_left, loader_score_save (6 bytes) = score[0..5],
    \ loader_hiscore_save (6 bytes) = the high-score buffer.
    JSR check_new_high_score
    LDX #&00
.L30FD
    LDA score,X
    STA loader_score_save,X
    LDA high_score,X
    STA loader_hiscore_save,X
    INX
    CPX #&06
    BNE L30FD
    LDA lives_left
    STA loader_lives_save
    RTS

.restore_score_from_loader
    \ Restore score / high-score from the loader persistence area into lives_left, score[0..5], and
    \ the high-score buffer. Called by main_init at game start.
    LDX #&00
.L3117
    LDA loader_score_save,X
    STA score,X
    LDA loader_hiscore_save,X
    STA high_score,X
    INX
    CPX #&06
    BNE L3117
    LDA loader_lives_save
    STA lives_left
    LDA #&20
    STA scratch_28D3
.L3133
    LDX scratch_28D3
    LDY #&57
    JSR calc_screen_addr
    LDA #LO(gfx_icon_lives_intro)
    STA sprite_src_lo
    LDA #HI(gfx_icon_lives_intro)
    STA sprite_src_hi
    LDX #&01
    LDY #&08
    JSR sprite_plot_xy
    INC scratch_28D3
    LDA scratch_28D3
    CMP #&26
    BNE L3133
    LDX #&20
    LDY #&57
    JSR calc_screen_addr
    LDX lives_left
    LDY #&08
    LDA #LO(gfx_icon_11)
    STA sprite_src_lo
    LDA #HI(gfx_icon_11)
    STA sprite_src_hi
    JMP sprite_plot_xy
    RTS

.pause_game
    \ PAUSE handler. Loops on `OSBYTE &81 / KEY_PAUSE` until the key is released, then loops again
    \ until KEY_PAUSE is pressed once more to resume. Returns when un-paused.
    LDX #&10
    LDY #&D0
    JSR calc_screen_addr
    LDA #LO(gfx_text_pause)
    STA sprite_src_lo
    LDA #HI(gfx_text_pause)
    STA sprite_src_hi
    LDX #&09
    LDY #&0E
    LDA #&01
    STA zp_sprite_dir_flag
    JSR sprite_plot_xy

.pause_wait_unpause
    LDX #&C9
    LDA #&81
    LDY #&FF
    JSR OSBYTE
    CPY #&FF
    BNE pause_wait_unpause
    LDX #&10
    LDY #&D0
    JSR calc_screen_addr
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    LDX #&09
    LDY #&0E
    JMP sprite_plot_xy

.draw_final_scoreboard
    \ End-of-game scoreboard display. Calls shutter_fade then a sequence of ship/text plot helpers;
    \ followed by a 6-iteration plot loop. Triggered when lives_left != 6 in intro_or_scoreboard.
    JSR shutter_fade
    JSR ship_intro_frame_5
    JSR ship_intro_frame_4
    JSR ship_intro_frame_3
    JSR ship_intro_frame_2
    LDA #&00
    STA zp_print_idx
.L31C4
    JSR wait_one_frame
    LDX zp_print_idx
    LDY #&C8
    JSR calc_screen_addr
    LDX #&05
    LDY #&16
    LDA #LO(lev_player_sprite)
    STA sprite_src_lo
    LDA #HI(lev_player_sprite)
    STA sprite_src_hi
    JSR sprite_plot_xy
    INC zp_print_idx
    LDA zp_print_idx
    CMP #&06
    BNE L31C4
    RTS
    RTS
