\ ----- code &2975..&29D8 -----
.pod_fire
    LDA force_pod_state
    CMP #&01
    BEQ L297D
    RTS
.L297D
    LDX #n_player_bullets
.L297F
    LDA player_bullet_x,X
    CMP #&00
    BEQ L298C
    DEX
    CPX #n_player_bullets - n_player_fire_slots
    BNE L297F
    RTS
.L298C
    LDA force_pod_x
    STA player_bullet_x,X
    LDA force_pod_y
    SEC
    SBC #&05

.L2998
    STA player_bullet_y,X
    JSR sfx_fire
    RTS
.L299F
    LDX zp_player_x
    INX
    INX
    TXA
    CMP force_pod_x
    BEQ L29B4
    BCC L29B1
    INC force_pod_x
    JMP L29B4
.L29B1
    DEC force_pod_x
.L29B4
    LDA zp_player_y
    SEC
    SBC #&04
    CMP force_pod_y
    BEQ L293F
    BCC L29CC
    LDA force_pod_y
    CLC
    ADC #&04
    STA force_pod_y
    JMP L293F
.L29CC
    LDA force_pod_y
    SEC
    SBC #&04
    STA force_pod_y
    JMP L293F

