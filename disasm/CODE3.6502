    STA zp_string_ptr_hi
    LDA #&02
    LDX #&04
    LDY #&0E
    JSR print_doubled_string
    INC data_2051
    JSR sfx_fire
    LDX #&20
    LDY #&57
    JSR calc_screen_addr
    LDA #LO(gfx_icon_11)
    STA sprite_src_lo
    LDA #HI(gfx_icon_11)
    STA sprite_src_hi
    LDX data_2051
    LDY #&08
    JSR sprite_plot_xy
.L341A
    LDX #&02
.L341C
    LDY #&32
.L341E
