\ ----- code &3300..&3501 -----
.stage_loading_screen
    LDA #LO(str_loading)  \ Inter-level loading screen: prints 'LOADING' / 'PLEASE WAIT' then jumps to &30F8 (the level loader in CODE2).
    STA zp_string_ptr_lo
    LDA #HI(str_loading)
    STA zp_string_ptr_hi
    LDA #&03
    LDX #&07
    LDY #&06
    JSR print_doubled_string
    LDA #LO(str_please_wait)
    STA zp_string_ptr_lo
    LDA #HI(str_please_wait)
    STA zp_string_ptr_hi
    LDA #&02
    LDX #&05
    LDY #&0B
    JSR print_doubled_string
    JMP save_score_to_loader

.stage_clear_screen
    LDA #LO(str_wow)  \ Stage-clear celebration: 'WOW!' / 'LEVEL X COMPLETED' then 'BONUS X000' with a score-rolling animation; optional '+ EXTRA SHIP!' if score crosses the threshold; returns RTS.
    STA zp_string_ptr_lo
    LDA #HI(str_wow)
    STA zp_string_ptr_hi
    LDA #&03
    LDX #&08
    LDY #&04
    JSR print_doubled_string
    LDA zp_level_num
    CLC
    ADC #&30
    STA data_363F
    STA data_3651
    LDA #LO(str_level_x_completed)
    STA zp_string_ptr_lo
    LDA #HI(str_level_x_completed)
    STA zp_string_ptr_hi
    LDA #&02
    LDX #&01
    LDY #&07
    JSR print_doubled_string
    LDA #LO(str_bonus_xnnn)
    STA zp_string_ptr_lo
    LDA #HI(str_bonus_xnnn)
    STA zp_string_ptr_hi
    LDA #&01
    LDX #&05
    LDY #&0A
    JSR print_doubled_string
    LDX #&32
.L3365
    STX zp_string_ptr_lo
    LDA #&13
    JSR OSBYTE
    LDX zp_string_ptr_lo
    DEX
    BNE L3365
    LDX zp_level_num
.L3373
    DEC data_3651
    LDA #&3A
    STA data_3652
    LDY #&FF
.L337D
    DEC data_3652
    INY
    STY KEY_UP
    STX zp_98
    JSR sfx_score_tick
    JSR draw_score
    INC score_d0
    LDA #LO(str_bonus_xnnn)
    STA zp_string_ptr_lo
    LDA #HI(str_bonus_xnnn)
    STA zp_string_ptr_hi
    LDA #&01
    LDX #&05
    LDY #&0A
    JSR print_doubled_string
    LDY KEY_UP
    LDX zp_98
    LDA score_d0
    CMP #&0A
    BNE L33D0
    LDA #&00
    STA score_d0
    INC score_d1
    LDA score_d1
    CMP #&0A
    BNE L33D0
    LDA #&00
    STA score_d1
    INC score_d2
    LDA score_d2
    CMP #&0A
    BNE L33D0
    LDA #&00
    STA score_d2
    INC score_d3
.L33D0
    CPY #&09
    BNE L337D
    DEX
    BNE L3373
    JSR draw_score
    LDX #&32
.L33DC
    STX zp_string_ptr_lo
    LDX zp_string_ptr_lo
    DEX
    BNE L33DC
    LDA data_2051
    CMP #&06
    BEQ L341A
