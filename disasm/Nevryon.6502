\ ============================================================
\ Nevryon — unified BeebAsm source
\ ============================================================
\ Builds all four runtime binaries — CODE, CODE2, CODE3, GRAPHIX —
\ from the per-binary .6502 source files in this directory. Labels
\ defined in any included file are visible to all the others, so
\ cross-file calls can use real label names once they're added to
\ the corresponding .cfg.json file.
\
\ Run from the disasm/ directory:
\     beebasm -i Nevryon.6502 -v
\ (or use ../build.sh / ..\build.bat which set the output directory)
\
\ The four output binaries match the original $.CODE, $.CODE2,
\ $.CODE3 and $.GRAPHIX byte-for-byte. CODE3 and GRAPHIX overlap
\ in RAM at &3680..&368F — GRAPHIX is loaded last in the real boot
\ chain, so its bytes win in memory. The assembly order below
\ saves CODE3 before GRAPHIX overwrites that 16-byte tail.

\ ----- Shared externs ----------------------------------------

\ Zero-page locations used by the engine. Pre-declare everything we
\ name so per-binary cfgs can reference any zp slot without forward-
\ reference issues (BeebAsm pass divergence on undefined symbols can
\ leave a silently corrupt layout — see Session 6 notes).
zp_old_irq_vec_lo         = &0064
zp_old_irq_vec_hi         = &0065
zp_screen_ptr_lo          = &0070
zp_screen_ptr_hi          = &0071
zp_sprite_cols_remaining  = &0074
zp_sprite_height          = &0075
zp_dest_x_lo              = &0076
zp_dest_x_hi              = &0077
zp_sprite_end_index       = &0078
zp_sprite_dir_flag        = &0079
zp_frame_progress         = &007A
zp_scroll_col             = &0080
zp_player_x               = &0081
zp_player_y               = &0082
zp_test_x                 = &0083
zp_test_y                 = &0084
\ Map-tile source pointers. Misnamed historically as
\ "zp_sprite_src" — these are NOT the sprite engine's source bytes
\ (those are the self-modified operand at sprite_src_lo / _hi at
\ &1194/&1195 inside sprite_plot_inner). They're the per-column
\ tile pointers used by L13D1: each frame walks the LEVD2 tile-id
\ table to compute where to read the current column's tile from in
\ the LEVD1 catalog at &4E80. Two pairs because the upper and lower
\ tile bands are drawn in the same column update from different
\ sources — the upper band is rendered with zp_sprite_dir_flag=0
\ (vertically mirrored, used by L127B at Y=&FF / row 0), the lower
\ band with dir_flag=1 (normal, Y=&7F / row 16).
zp_tile_lower_hi          = &008B
zp_tile_lower_lo          = &008C
zp_tile_upper_hi          = &008D
zp_tile_upper_lo          = &008E
zp_get_ready_erase        = &008F
zp_print_idx              = &0090
zp_continues              = &0091
zp_game_speed             = &0092
zp_string_ptr_lo          = &0095
zp_string_ptr_hi          = &0096
zp_score_acc              = &009B
zp_irq_enable             = &009C
zp_level_num              = &009D

\ Interrupt vectors
irq1v_lo                  = &0204
irq1v_hi                  = &0205

\ ---- Active-object pool sizes ------------------------------
\ Caps on how many of each kind of game object can exist at
\ once. See docs/memory_map.md "Active-object pools" for the
\ full table (per-pool storage, iterator pattern, sharing).
\ Singletons (force-pod, flame, force-field, pickup, player
\ ship, player explosion) are not given a constant — they're
\ scalars with no slot index.

n_hazards                 = 8     \ Hazard slots, indexed 0..n_hazards-1. update_hazards iterates 0..7 (CPX #n_hazards), spawn_check_step round-robins via zp_7C.
n_enemies                 = 8     \ Enemy slots, indexed 1..n_enemies. Iterators are predec loops (LDX #n_enemies / DEX / BNE), so slot 0 is unused. Shares the hazard_x/_y/_type/_hp/_step backing arrays with the hazards — enemies live at indices 1..8, hazards at 0..7, union 0..8 = n_state_slots wide.
n_state_slots             = 9     \ Width of the combined hazard+enemy backing arrays (hazard_x at &2052 through enemy_state at &208A, each 9 bytes). init clears the union of [0..n_hazards-1] ∪ [1..n_enemies] = [0..8].
n_npc_bullets           = 6     \ NPC bullet slots scanned by update_npc_bullets and enqueue_npc_bullet — indexed 1..n_npc_bullets (predec loop). The backing arrays npc_bullet_x/_y at &1A8B/&1A92 are 7 bytes wide; slot 0 is initialised to &FF but never used by either routine.
n_enemy_npc_bullets          = 4     \ Enemies (via npc_bullet_alloc) only fire into the first n_enemy_npc_bullets slots of the shared npc_bullet pool — indices 1..4. Hazard-type-&04/&13 fires can use the full 1..6 range, so slots 5..6 are effectively reserved for hazards.
n_hazard_missiles          = 2     \ Hazard missile slots, indexed 0..n_hazard_missiles-1 (no loop — hard-coded LDX #&00 / LDX #&01 in update_hazard_missiles).
n_player_bullets          = 6     \ Player bullet slots, indexed 1..n_player_bullets. update_bullets predec-loops over all 6; on_fire_pressed only scans 1..n_player_fire_slots so the upper 2 slots (5,6) are reserved for the force-pod's twin shot.
n_player_fire_slots       = 4     \ Number of in-flight bullets the fire button can put on screen. on_fire_pressed scans player_bullet_x[n_player_fire_slots..1] for a free slot.

\ ---- State-machine enumerations ----------------------------
\ Named values that appear in the enemy_state / hazard_type bytes
\ and in the per-axis pattern-direction scratch (data_16F6, _16F7).
\ Reflected in the disasm via immediate_overrides at the sites that
\ literally compare against or store these values; the underlying
\ bytes are unchanged and the build still roundtrips bit-identical.

\ ---- enemy_state values --------
\ Animation / lifecycle counter for each enemy slot (&1A6B+X).
\ Values 1..7 = alive (INC'd through the hit-count up to the kill
\ threshold), 9 = invincibility ceiling (CPY #&09 BCC = "hittable"),
\ &0A..&0D = death-animation frames, &00 = slot free.
\ enemy_state_initial_pat5 / _initial_pat6 happen to share their
\ numeric values with the kill thresholds for the previous pattern
\ (state &03 = "pattern 5 just spawned" = "pattern 1..4 + 2 hits").
\ The per-PC override picks the name that fits each use site.
enemy_state_inactive          = &00     \ slot free / death-anim done; also CPY's BEQ-fall-through "active?" test
enemy_state_initial_pat14     = &01     \ initial state set by spawn_periodic_enemy for patterns 1..4
enemy_state_initial_pat5      = &03     \ initial state for pattern 5 (player-homing)
enemy_state_kill_pat14        = &03     \ patterns 1..4 enemy reaches this after 2 hits = killed
enemy_state_initial_pat6      = &05     \ initial state for pattern 6 (straight-at-player)
enemy_state_kill_pat5         = &05     \ pattern 5 enemy reaches this after 2 hits = killed
enemy_state_kill_pat6         = &07     \ pattern 6 enemy reaches this after 2 hits = killed
enemy_state_invincible_min    = &09     \ CPY #&09 BCC: states 1..8 = hittable, &09+ = invincible / dying
enemy_state_hit_frame_1       = &0A     \ death-anim frame 1 (sprite = lev_enemy_hit_1)
enemy_state_hit_frame_2       = &0B     \ death-anim frame 2 (sprite = lev_enemy_hit_2)
enemy_state_hit_frame_3       = &0C     \ death-anim frame 3 (sprite = lev_enemy_hit_3)
enemy_state_hit_erase         = &0D     \ final erase frame; slot cleared back to &00

\ ---- hazard_type values --------
\ Each hazard slot (hazard_type[X] at &2065+X) is a small state
\ machine: 0 = free, 1..3 = three-frame decor anim loop, &04 / &06 /
\ &07 / &08 / &13 = per-frame action types (fire bullet / fire
\ missile / force-field / fire flame / fire bullet variant), &09 =
\ post-flame idle, &0F↔&10 = two-frame anim ping-pong, &14..&1B =
\ death-anim frames, &1C = clear-slot marker.
hazard_type_inactive          = &00
hazard_type_fires_bullet_a    = &04     \ per-frame: enqueue_npc_bullet (white 4×2 leftward bullet)
hazard_type_fires_missile     = &06     \ per-frame: spawn_hazard_missile (CODE2 — homing rocket)
hazard_type_forcefield        = &07     \ per-frame: forcefield_render (the slot IS the force-field)
hazard_type_fires_flame       = &08     \ per-frame: spawn_flame; mutates self to &09 on success
hazard_type_flame_idle        = &09     \ post-flame idle (anim toggles &08 ↔ &09)
hazard_type_anim_ping_a       = &0F     \ 2-frame ping-pong with &10 (anim_set_type_10)
hazard_type_anim_ping_b       = &10     \ 2-frame ping-pong with &0F (anim_set_type_F)
hazard_type_fires_bullet_b    = &13     \ per-frame: enqueue_npc_bullet (second bullet-firing variant)
hazard_type_death_start       = &14     \ set on kill (check_bullet_hits / check_player_collisions / missile_hazard_box_test) — starts the &14..&1B death-anim chain
hazard_type_death_clear       = &1C     \ hazard_death_step clears the slot when type reaches this

\ ---- pattern_dir values --------
\ Per-axis direction selector emitted by L1B87's pattern walker;
\ consumed by L1B2D. Convention: 0 = no motion, 1 = positive
\ (Y += 4 = UP / X += 1 = right), anything else (3 is the stored
\ value) = negative (Y -= 4 = DOWN / X -= 1 = left). Stored in
\ data_16F6 (dy) and data_16F7 (dx); the consumer tests CMP #&01
\ BNE → "negative" so any non-zero non-one value falls through.
pattern_dir_none              = &00
pattern_dir_pos               = &01
pattern_dir_neg               = &03

\ ---- Per-level data (LEVD1 / LEVD2 / LEVD3) ----------------
\ Each scenario (and per stage) reloads these three files into
\ fixed CPU regions. LEVD1 is per-scenario only; LEVD2 / LEVD3
\ also vary per stage within a scenario.
\
\ The level files contain six categories of sprite data, all in
\ column-major 4-bit MODE-5 form, with the per-scenario palette
\ supplying colour. Categories (and the lev_* names used below):
\
\   explosion_N (N=0..5)     6 frames of player death animation,
\                            split LEVD1 (frames 0..3) + LEVD2
\                            (frames 4..5). Played by death_anim
\                            (CODE &1E47). Frame size 4×32 (128 B).
\   enemy_N     (N=0..3)     4 frames of the per-scenario small
\                            flying enemy. 4×24 (96 B), with
\                            column sharing — adjacent frames
\                            overlap by 24 B (= 1 col).
\   enemy_hit_N (N=1..3)     3 frames of the same enemy's damage /
\                            destruction cycle. 4×24 (96 B).
\   tile_NN     (N=0..17)    18 slots of the per-scenario map tile
\                            catalog. 4×32 (128 B); indexed by
\                            lev_map_upper / lev_map_lower.
\   hazard_NN   (N=0..13)    14 per-stage hazard sprites — the
\                            larger stationary threats (gun towers,
\                            tanks, etc.). 4×32 (128 B); indexed
\                            via lev_hazard_ptr_* slots 1..14.
\   player_sprite            6×22 (132 B) — the player ship.

\ LEVD1 — per-scenario explosion + enemy + player + tile catalog
\ (loaded at &4A00, length &E00, fills &4A00..&57FF)
lev_explosion_0           = &4A00     \ 4×32 (128 B) — frame 0 of the 6-frame explosion played by death_anim
lev_explosion_1           = &4A80
lev_explosion_2           = &4B00
lev_explosion_3           = &4B80
\ &4C00..&4C1F            \ 32 B zero pad
lev_enemy_hit_1           = &4C20     \ 4×24 (96 B) — first of 3 enemy hit/destruction frames (state machine in L1BE3)
lev_enemy_hit_2           = &4C68
lev_enemy_hit_3           = &4CB0
lev_enemy_0               = &4D00     \ 4×24 (96 B) — first of 4 normal enemy frames (state machine in L1BE3)
lev_enemy_1               = &4D48
\ &4DA8..&4DAF            \ 8 B zero pad
lev_enemy_2               = &4DB0
lev_enemy_3               = &4E10
\ &4E70..&4E7F            \ 16 B zero pad
lev_player_sprite         = &4E80     \ 6×22 (132 B) — player ship; last 4 bytes overlap tile_0's first 4 bytes
lev_tile_catalog          = &4F00     \ 18 tile slots × 4×32 (128 B each); tile N at lev_tile_catalog + N*&80

\ LEVD2 / LEVD3 — per-stage enemies, spawns, explosion-tail, map tile-id streams
\ (loaded at &7380, length &C80 = 3200 B for LEVD2 and 4.LEVD3; &880 = 2176 B for 1-3.LEVD3 which overwrites only the lower half)
lev_hazard_0              = &7380     \ 4×32 (128 B) — first of 14 hazard sprites (gun towers, tanks, etc.). Accessible via lev_hazard_ptr_lo/hi[1..14].
lev_hazard_1              = &7400
lev_hazard_2              = &7480
lev_hazard_3              = &7500
lev_hazard_4              = &7580
lev_hazard_5              = &7600
lev_hazard_6              = &7680
lev_hazard_7              = &7700
lev_hazard_8              = &7780
lev_hazard_9              = &7800
lev_hazard_10             = &7880
lev_hazard_11             = &7900
lev_hazard_12             = &7980
lev_hazard_13             = &7A00
lev_hazard_ptr_lo          = &7A80     \ 32-slot hazard sprite-pointer table (LO byte). Indexed by hazard attribute's "type" field (bits 0..4). Slots 1..14 point at lev_hazard_0..13; slots 15/16/19 point into $.GRAPHIX (shared cross-scenario); slots 17/18 point into lev_tile_catalog (reused tile bytes as hazard sprites); slots 21..26 are the 6 explosion-frame source pointers (see lev_explosion_ptr_lo below); slots 0/27 = lev_erase_brush; 20, 28..31 unused (&0000).
lev_hazard_ptr_hi          = &7AC0     \ 32-slot hazard sprite-pointer table (HI byte). Paired with lev_hazard_ptr_lo.
\ Slots 21..26 of the hazard pointer table double as the 6 source
\ pointers for the explosion animation. The two names refer to the
\ same physical bytes — lev_explosion_ptr_* is just an alias of the
\ tail of lev_hazard_ptr_*.
lev_explosion_ptr_lo      = &7A95     \ = lev_hazard_ptr_lo + &15 (slots 21..26)
lev_explosion_ptr_hi      = &7AD5     \ = lev_hazard_ptr_hi + &15
lev_spawn_col             = &7B00     \ 128-byte spawn-column schedule (sorted ascending; &FF = end-of-list)
lev_spawn_attr            = &7B80     \ 128-byte spawn attribute table, parallel with lev_spawn_col. Bits 0..4 = hazard type / dispatch (→ hazard_type_dispatch), bits 5..6 = Y row (0 = &DF, 1 = &BF, 2 = &9F, 3 = &7F), bit 7 = vertical-flip flag (mirrors the sprite, used to pair ceiling-hanging and floor-rising decoration hazards).
lev_explosion_4           = &7C00     \ 4×32 (128 B) — frame 4 of the 6-frame explosion. Same bytes accessible via lev_hazard_ptr_*[25].
lev_explosion_5           = &7C80     \ 4×32 (128 B) — frame 5 of the 6-frame explosion. Same bytes accessible via lev_hazard_ptr_*[26].
lev_erase_brush           = &7D00     \ 256 bytes of zeros (genuine erase brush) at &7D00..&7DFF + 16-byte tail at &7E00..&7E0F that holds the NPC bullet sprites (poked at game-load by Loader2 line 1060, NOT shipped in any LEVD2 file — the on-disk bytes are zero and Loader2 patches them in RAM after load). Read by sprite_plot_xy: erase calls at offsets 0 / &80 produce a black rectangle; bullet plots at offsets &100 (hazard) / &102 (player) read 6 bytes (3×2) that include the visible sprite byte plus 4 zero bytes of trailing-erase pad in the direction of motion.
npc_bullet_sprite      = &7E00     \ 1-col × 2-line (4×2 px) NPC bullet sprite, two bytes &77 = pixels (black, white, white, white) — palette value 3 (always white). Loader2 line 1060: `?&7E00 = ?&7E01 = 119`. Plotted by update_npc_bullets via a 3×2 sprite_plot_xy from `lev_erase_brush + &100` (= here): col 0 = the visible white strip, cols 1-2 = zero pad that erases the trail since NPC bullets move LEFT 2 px per frame.
player_bullet_sprite      = &7E06     \ 1-col × 2-line (4×2 px) player bullet sprite, two bytes &70 = pixels (black, palette-2, palette-2, palette-2). Per-scenario palette value 2 = yellow (L1) / cyan (L2) / green (L3) / magenta (L4). Loader2 line 1060: `?&7E06 = ?&7E07 = 112`. Plotted by update_bullets via a 3×2 sprite_plot_xy from `lev_erase_brush + &102` (= here − 4): cols 0-1 = zero pad that erases the trail (player bullets move RIGHT 2 px per frame), col 2 = the visible coloured strip.
\ Map tile-id streams. Each is 240 entries, one byte per scroll
\ column, indexing into lev_tile_catalog. The upper band is
\ rendered at char-row 0 with dir_flag = 0 (vertically mirrored,
\ so the same floor-shaped tile data appears as a ceiling), the
\ lower band at char-row 16 with dir_flag = 1 (normal). Read by
\ L13D1 which writes the resolved pointers into zp_tile_upper /
\ zp_tile_lower.
lev_map_upper             = &7E10     \ 240-byte upper tile-id stream (drives zp_tile_upper; drawn mirrored at row 0)
lev_map_lower             = &7F10     \ 240-byte lower tile-id stream (drives zp_tile_lower; drawn normal at row 16)

\ Internal BBC key scan codes (OSBYTE &81 with Y=&FF, X=&XX). These
\ map to BASIC's `INKEY -N` values. The byte stored in X is the two's
\ complement of the BASIC scan code, e.g. KEY_RIGHT = &BD = -67 mod
\ 256 → INKEY -67. check_key_pressed in CODE wraps the call.
KEY_RIGHT                 = &BD     \ INKEY -67  (the "X" key)
KEY_LEFT                  = &9E     \ INKEY -98  (the "Z" key)
KEY_UP                    = &B7     \ INKEY -73
KEY_DOWN                  = &97     \ INKEY -105
KEY_FIRE                  = &B6     \ INKEY -74
KEY_PAUSE                 = &C8     \ INKEY -56
KEY_QUIT                  = &8F     \ INKEY -113 (force game over)

\ Loader2 / Loader4 persistence area (page &C, &0CF3..&0CFF).
\ save_score_to_loader / restore_score_from_loader move state here
\ across the BASIC chain.
loader_lives_save         = &0CF3
loader_score_save         = &0CF4
loader_hiscore_save       = &0CFA

\ Cross-file labels referencing bytes that LIVE inside one of the
\ binaries (e.g. score_dN at &2A02 in CODE2, data_2051 at &2051 in
\ CODE) are defined inline by that binary's cfg, not here — the
\ disassembler emits them at the byte location and they're visible
\ globally once BeebAsm has INCLUDE'd the binary.

\ Cross-file LXXXX labels (auto-generated from branch targets) and
\ mid-instruction equates (sprite_src_lo/hi, LXXXX inside CODE2 etc.)
\ are emitted inline in each per-binary .6502 file, not here.

\ BBC hardware (VIA + palette)
via_palette_latch         = &FE21
svia_ifr                  = &FE4D
uvia_t1l_l                = &FE64
uvia_t1l_h                = &FE65
uvia_acr                  = &FE6B
uvia_ifr                  = &FE6D
uvia_ier                  = &FE6E

\ MOS API
OSRDCH                    = &FFE0
OSWRCH                    = &FFEE
OSWORD                    = &FFF1
OSBYTE                    = &FFF4
OSCLI                     = &FFF7


\ ----- $.CODE — &1100..&27E6 (5863 B) -------------------------
INCLUDE "CODE.6502"
SAVE "../build/CODE",    &1100, &27E7

\ ----- $.CODE2 — &2800..&31E8 (2537 B) ------------------------
INCLUDE "CODE2.6502"
SAVE "../build/CODE2",   &2800, &31E9

\ ----- $.CODE3 — &3300..&368F (912 B) -------------------------
\ Save before GRAPHIX is assembled — its last 16 B share RAM with
\ GRAPHIX's first 16 B. The CLEAR below releases that range so
\ GRAPHIX can re-assemble into it.
INCLUDE "CODE3.6502"
SAVE "../build/CODE3",   &3300, &3690
CLEAR &3680, &3690

\ ----- $.GRAPHIX — &3680..&49FF (4992 B) ----------------------
INCLUDE "GRAPHIX.6502"
SAVE "../build/GRAPHIX", &3680, &4A00
