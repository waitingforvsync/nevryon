.screen_row_lo_lut
    \ Screen char-row low-byte LUT — MODE 5 with base &5800, stride &140 per char row
    EQUB &00, &40, &80, &C0, &00, &40, &80, &C0
    EQUB &00, &40, &80, &C0, &00, &40, &80, &C0
    EQUB &00, &40, &80, &C0, &00, &40
.screen_row_hi_lut
    \ Screen char-row high-byte LUT — pairs with screen_row_lo_lut
    EQUB &58, &59, &5A, &5B, &5D, &5E, &5F, &60
    EQUB &62, &63, &64, &65, &67, &68, &69, &6A
    EQUB &6C, &6D, &6E, &6F, &71, &72, &EA

\ ----- code &1236..&1307 -----
.calc_screen_addr
    TYA  \ Compute screen address from X (char-col) and Y (logical row); result in $76/$77
    EOR #&FF
    TAY
    AND #&07
    STA zp_dest_x_hi
    TYA
    LSR A
    LSR A
    LSR A
    TAY
    LDA screen_row_lo_lut,Y
    STA zp_dest_x_lo
    LDA zp_dest_x_hi
    CMP #&08
    BEQ L1252
    ADC zp_dest_x_lo
    STA zp_dest_x_lo
.L1252
    LDA screen_row_hi_lut,Y
    STA zp_dest_x_hi
    TXA
    BEQ L126B
    TAY
    CLC
.L125C
    LDA zp_dest_x_lo
    ADC #&08
    STA zp_dest_x_lo
    LDA zp_dest_x_hi
    ADC #&00
    STA zp_dest_x_hi
    DEY
    BNE L125C
.L126B
    RTS

.scroll_step
    LDA zp_scroll_col  \ Per-frame scroll entry. If zp_scroll_col has reached &F0 (the wrap point — last 240 columns of the map loop forever), restart the starfield and jump straight to update_hazards, skipping the scroll. Otherwise fall through to scroll_playfield.
    CMP #&F0
    BNE scroll_playfield
    JSR starfield_init
    JMP update_hazards
    JMP update_hazards

.scroll_playfield
    JSR starfield_update  \ Soft-scroll the playfield's upper and lower tile bands left by 8 pixels (one BBC char cell = 2 byte-cols), then plot the new column at the right edge (col 39). The inner copy loop is unrolled into two parallel pairs of self-modified `LDA &XXXX / STA &XXXX` instructions — one pair for the upper band (HI = &58 → screen row 0), one for the lower band (HI = &6C → screen row 16). The eight self-modified operand bytes are named `scroll_{upper,lower}_{src,dst}_{lo,hi}` and are incremented in tandem by the loop. Outer counter X=5 + inner loop runs 256 iterations each ⇒ 5×256 = 1280 bytes per band copied (= 4 char rows × 320 B/row, the full band). On exit, plot the freshly-scrolled-in column at (col &27, row 0) mirrored from zp_tile_upper, then (col &27, row 16) normal from zp_tile_lower.
    JSR update_hazards
    JSR get_ready_overlay
    LDX #&27
    LDY #&FF
    JSR calc_screen_addr
    LDA #&00
    STA scroll_upper_dst_lo
    STA scroll_lower_dst_lo
    STA zp_sprite_dir_flag
    LDA zp_tile_upper_lo
    STA sprite_src_lo
    CLC
    ADC #&20
    STA zp_tile_upper_lo
    LDA zp_tile_upper_hi
    STA sprite_src_hi
    LDA #&58
    STA scroll_upper_src_hi
    STA scroll_upper_dst_hi
    LDA #&6C
    STA scroll_lower_src_hi
    STA scroll_lower_dst_hi
    LDX #&05
    LDA #&08
    STA scroll_lower_src_lo
    STA scroll_upper_src_lo

.scroll_inner_loop
scroll_lower_src_lo = * + 1
scroll_lower_src_hi = * + 2
    LDA &FFFF  \ Inner body of scroll_playfield's copy loop. The four `LDA &FFFF / STA &FFFF` instructions use the literal &FFFF only as a placeholder — at runtime each instruction's operand bytes (the `scroll_{upper,lower}_{src,dst}_{lo,hi}` equates defined immediately above each LDA/STA via `* + 1` / `* + 2`) have been pre-set to a real screen address, then INC'd at the bottom of the loop. Each iteration's `LDA` reads one byte further right and the matching `STA` writes one byte further left, sliding the band leftward.
scroll_lower_dst_lo = * + 1
scroll_lower_dst_hi = * + 2
    STA &FFFF
scroll_upper_src_lo = * + 1
scroll_upper_src_hi = * + 2
    LDA &FFFF
scroll_upper_dst_lo = * + 1
scroll_upper_dst_hi = * + 2
    STA &FFFF
    INC scroll_lower_src_lo
    INC scroll_upper_src_lo
    BNE scroll_inner_advance
    INC scroll_lower_src_hi
    INC scroll_upper_src_hi

.scroll_inner_advance
    INC scroll_lower_dst_lo
    INC scroll_upper_dst_lo
    BNE scroll_inner_loop
    INC scroll_lower_dst_hi
    INC scroll_upper_dst_hi
    DEX
    BNE scroll_inner_loop
    JSR sprite_plot_default
    LDX #&27
    LDY #&7F
    JSR calc_screen_addr
    INC zp_sprite_dir_flag
    LDA zp_tile_lower_lo
    STA sprite_src_lo
    CLC
    ADC #&20
    STA zp_tile_lower_lo
    LDA zp_tile_lower_hi
    STA sprite_src_hi
    JMP sprite_plot_default

