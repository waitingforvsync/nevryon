\ ----- code &1100..&116B -----
.main_init
    JSR restore_score_from_loader  \ Entry: restore saved score, run per-level init, draw the title screen, then drop into main_loop. Called as `CALL &1100` from BASIC Runner/Loader4 on each level start.
    JSR init
    JSR draw_title_screen

.main_loop
    JSR game_step
    LDA lives_left
    BNE L1114
    JMP game_over_or_continue
.L1114
    LDX #KEY_QUIT
    JSR check_key_pressed
    BNE L1130
    LDA #&01
    STA lives_left
    JSR death_anim
    LDA #&00
    STA zp_level_num
    JSR save_score_to_loader
    JSR play_death_sequence
    JMP stage_loading_screen
.L1130
    LDA data_268F
    BEQ main_loop
    JSR stage_clear_screen
    JSR shutter_fade
    JMP stage_loading_screen
    JMP main_loop

.lfsr_random
    LDY #&20  \ LFSR pseudo-random generator. Runs 32 rounds of `LSR / EOR zp_11 / ROR / ROL` across the 5-byte state at zp_0D..zp_11 (Galois-style 40-bit LFSR — the bit dropped each round is fed back through zp_11). On return, four progressively right-shifted slices of the result byte are stored so callers can pick a bin size without further shifting: rndval256 (0..255), rndval64 (0..63 = raw>>2), rndval32 (0..31 = raw>>3), rndval16 (0..15 = raw>>4). Used heavily by the starfield and force-field renderers.
.L1143
    LDA zp_0F
    LSR A
    LSR A
    LSR A
    EOR zp_11
    ROR A
    ROL zp_0D
    ROL zp_0E
    ROL zp_0F
    ROL zp_10
    ROL zp_11
    DEY
    BNE L1143
    LDA zp_0D
    STA rndval256
    LSR A
    LSR A
    STA rndval64
    LSR A
    STA rndval32
    LSR A
    STA rndval16
    RTS

