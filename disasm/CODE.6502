    BEQ L157F
    RTS
.L157F
    LDA player_missile_step
    BEQ L1585
    RTS
.L1585
    LDX zp_player_x
    STX player_missile_x
    STX player_missile_x + 1
    LDA zp_player_y
    CLC
    ADC #&02
    STA player_missile_y
    SEC
    SBC #&14
    STA player_missile_y + 1
    LDA #&01
    STA player_missile_active
    STA player_missile_active + 1
    LDA #&01
    STA player_missile_frame
    LDA #&01
    STA player_missile_step
    LDA zp_player_y
    CMP #&D8
    BCS L15B8
    CMP #&A0
