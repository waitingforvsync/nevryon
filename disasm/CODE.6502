    LDA lev_map_upper,X
    TAX
    INX
    LDA #&4E
    STA zp_tile_upper_hi
    LDA #&80
    STA zp_tile_upper_lo
    LDA #&00
    STA zp_dest_x_lo
.L1411
    INC zp_dest_x_lo
    LDA zp_tile_upper_lo
    CLC
    ADC #&80
    STA zp_tile_upper_lo
    BNE L141E
    INC zp_tile_upper_hi
.L141E
    CPX zp_dest_x_lo
