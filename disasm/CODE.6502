\ ----- data &268F..&2693 -----
.data_268F
    EQUB &EA
.pickup_x
    \ Power-up pickup X coordinate (column). DEC'd by 1 each subframe of game_step (so the pickup drifts leftward 16 px/sec = 4 px per game_step). When it hits 0, update_pickup deactivates and erases. Initial value &27 (right edge) on spawn from try_spawn_pickup.
    EQUB &EA
.pickup_y
    \ Power-up pickup Y coordinate (scanline) — captured from player_y at the moment try_spawn_pickup ran, then held constant for the lifetime of the pickup.
    EQUB &EA
.pickup_state
    \ Power-up pickup state: 0 = inactive (slot free for a new spawn). Non-zero = active, with the value selecting the sprite frame for the flashing animation (2/6 → gfx_pickup_yellow, 3/5 → gfx_pickup_red, others → erase) — wraps at &0A back to 1.
    EQUB &EA

\ ----- code &2693..&27E7 -----
.update_pickup
    LDA pickup_state  \ Per-subframe power-up pickup updater. Returns immediately if pickup_state == 0. Otherwise calls L275F (collision test?), conditionally advances state, DECs pickup_x (drifts the pickup leftward 1 px per subframe), and on pickup_x == 0 deactivates and erases. While alive, plots one of two sprites (`gfx_pickup_yellow` or `gfx_pickup_red`) keyed on the current pickup_state value (state 2/6 = yellow, 3/5 = red, 4 = ?, others = erase) — gives the pickup a flashing animation as it crosses the playfield.
    BNE L2699
    RTS
.L2699
    JSR L275F
    LDA pickup_state
    BNE L26A2
    RTS
.L26A2
    LDA zp_7F
    CMP #&04
    BNE L26AB
    INC pickup_state
.L26AB
    DEC pickup_x
    LDA pickup_x
    BNE L26CF
    STA pickup_state
    LDX #&00
    LDY pickup_y
    JSR calc_screen_addr
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    LDX #&03
    LDY #&10
    JMP sprite_plot_xy
.L26CF
    LDX pickup_x
    LDY pickup_y
    JSR calc_screen_addr
    LDX #&03
    LDY #&10
    LDA pickup_state
    CMP #&01
    BEQ L2737
    CMP #&02
    BEQ L2703
    CMP #&03
    BEQ L2744
    CMP #&04
    BEQ L2751
    CMP #&05
    BEQ L2744
    CMP #&06
    BEQ L2703
    CMP #&0A
    BCC L2737
    LDA #&01
    STA pickup_state
    JMP L2737
.L2703
    LDA #LO(gfx_pickup_yellow)
    STA sprite_src_lo
    LDA #HI(gfx_pickup_yellow)
    STA sprite_src_hi
    JMP sprite_plot_xy
    LDA #LO(gfx_pickup_red)
    STA sprite_src_lo
    LDA #HI(gfx_pickup_red)
    STA sprite_src_hi
    JMP sprite_plot_xy
    LDA #LO(gfx_pickup_checker)
    STA sprite_src_lo
    LDA #HI(gfx_pickup_checker)
    STA sprite_src_hi
    JMP sprite_plot_xy
    LDA #LO(gfx_text_pause)
    STA sprite_src_lo
    LDA #HI(gfx_text_pause)
    STA sprite_src_hi
    JMP sprite_plot_xy
.L2737
    LDA #LO(gfx_pickup_red)
    STA sprite_src_lo
    LDA #HI(gfx_pickup_red)
    STA sprite_src_hi
    JMP sprite_plot_xy
.L2744
    LDA #LO(gfx_pickup_checker)
    STA sprite_src_lo
    LDA #HI(gfx_pickup_checker)
    STA sprite_src_hi
    JMP sprite_plot_xy
.L2751
    LDA #LO(gfx_pickup_white)
    STA sprite_src_lo
    LDA #HI(gfx_pickup_white)
    STA sprite_src_hi
    JMP sprite_plot_xy
.L275E
    RTS

.L275F
    LDX zp_player_x
    DEX
    TXA
    CMP pickup_x
    BCS L275E
    ADC #&06
    CMP pickup_x
    BCC L275E
    LDA zp_player_y
    CLC
    ADC #&04
    CMP pickup_y
    BCC L275E
    SBC #&1C
    CMP pickup_y
    BCS L275E
    LDA #&00
    STA pickup_state
    LDX pickup_x
