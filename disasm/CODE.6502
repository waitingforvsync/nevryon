    CLC
.L168F
    ADC #&28
    DEX
    BNE L168F
    SEC
    SBC #&28
    STA sprite_src_lo
    LDA #&44
    STA sprite_src_hi
    LDX #&05
    LDY #&08
    JMP sprite_plot_xy

