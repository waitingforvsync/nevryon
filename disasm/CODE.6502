\ ----- code &1100..&116B -----
.main_init
    \ Main game entry point — called as `CALL &1100` from BASIC Runner / Loader4 on each level
    \ start. Restores the saved score from the loader persistence area at &0CF3+, runs per-level
    \ `init`, draws the title screen, then drops into `main_loop`.
    \
    \ Inputs: ?&9D = current level number (set by Runner).
    \
    \ Effects: restores score / lives / scoreboard state; resets per-level engine state.
    JSR restore_score_from_loader
    JSR init
    JSR draw_title_screen

.main_loop
    JSR game_step
    LDA lives_left
    BNE L1114
    JMP game_over_or_continue
.L1114
    LDX #KEY_QUIT
    JSR check_key_pressed
    BNE L1130
    LDA #&01
    STA lives_left
    JSR death_anim
    LDA #&00
    STA zp_level_num
    JSR save_score_to_loader
    JSR play_death_sequence
    JMP stage_loading_screen
.L1130
    LDA stage_clear_flag
    BEQ main_loop
    JSR stage_clear_screen
    JSR shutter_fade
    JMP stage_loading_screen
    JMP main_loop

.lfsr_random
    \ 40-bit Galois-style LFSR pseudo-random generator. Runs 32 rounds of `LSR / EOR zp_11 / ROR /
    \ ROL` across the 5-byte state at zp_0D..zp_11 (the bit dropped each round feeds back through
    \ zp_11). On return, four progressively right-shifted slices of the raw result are pre-computed
    \ so callers can pick a bin size without shifting themselves.
    \
    \ Inputs: 5-byte state at zp_0D..zp_11 (seeded by init; must be non-zero).
    \
    \ Outputs:
    \ rndval256 = raw byte, 0..255
    \ rndval64  = raw >> 2, 0..63
    \ rndval32  = raw >> 3, 0..31
    \ rndval16  = raw >> 4, 0..15
    \
    \ Heavy users: starfield_update (one rndval256 read per star per frame) and forcefield_render
    \ (reads rndval256 to pick a sideways-ROM offset per noise byte).
    LDY #&20
.L1143
    LDA zp_0F
    LSR A
    LSR A
    LSR A
    EOR zp_11
    ROR A
    ROL zp_0D
    ROL zp_0E
    ROL zp_0F
    ROL zp_10
    ROL zp_11
    DEY
    BNE L1143
    LDA zp_0D
    STA rndval256
    LSR A
    LSR A
    STA rndval64
    LSR A
    STA rndval32
    LSR A
    STA rndval16
    RTS

\ ----- data &116B..&116F -----
.rndval256
    EQUB &EA
.rndval64
    EQUB &EA
.rndval32
    EQUB &EA
.rndval16
    EQUB &EA

\ ----- code &116F..&1209 -----
.sprite_plot_default
    \ Convenience wrapper: plot a sprite with hard-coded width = 1 byte-col and height = &20
    \ scanlines, then fall into sprite_plot_xy.
    LDX #&01
    LDY #&20

.sprite_plot_xy
    \ Plot a column-major sprite to the screen. Walks W byte-cols × H scanlines through the source
    \ via the self-modified LDA at sprite_src_lo/_hi, writing pixel-bytes directly to screen RAM via
    \ the zp_screen_ptr that's set up internally from zp_dest_x. No blending — non-zero source bytes
    \ overwrite the screen, zero bytes blank to black (which is how erase brushes work).
    \
    \ Inputs:
    \ X = sprite width in byte-cols (each byte-col is 4 pixels wide)
    \ Y = sprite height in scanlines
    \ sprite_src_lo / _hi = source byte address (self-modified operand)
    \ zp_dest_x_lo / _hi = destination screen address (typically from calc_screen_addr)
    \ zp_sprite_dir_flag = 1 forward, 0 vertical-flip (source read back-to-front)
    \
    \ Clobbers: A, X, Y, zp_70..zp_78 scratch area.
    STX zp_sprite_cols_remaining
    STY zp_sprite_height
    STY zp_sprite_end_index
    LDX #&00
    LDA zp_sprite_dir_flag
    CMP #&01
    BEQ sprite_plot_inner
    LDX zp_sprite_height
    DEX

.sprite_plot_inner
    LDA zp_dest_x_lo
    AND #&F8
    STA zp_screen_ptr_lo
    LDA zp_dest_x_hi
    STA zp_screen_ptr_hi
    LDA zp_dest_x_lo
    AND #&07
    TAY

.sprite_plot_lda_sm
sprite_src_lo    = * + 1
sprite_src_hi    = * + 2
    LDA &FFFF,X
    STA (zp_screen_ptr_lo),Y
    LDA zp_sprite_dir_flag
    BEQ L11D5
    INX
    BEQ L1203
.L119F
    INY
    CPX zp_sprite_end_index
    BEQ L11BE
    CPY #&08
    BNE sprite_plot_lda_sm
    LDA zp_screen_ptr_lo
    ADC #&3F
    STA zp_screen_ptr_lo
    LDA zp_screen_ptr_hi
    ADC #&01
    STA zp_screen_ptr_hi
    LDY #&00
    BEQ sprite_plot_lda_sm
    INC sprite_src_hi
    JMP L119F
.L11BE
    CLC
    LDA zp_dest_x_lo
    ADC #&08
    STA zp_dest_x_lo
    BCC L11C9
    INC zp_dest_x_hi
.L11C9
    CLC
    LDA zp_sprite_end_index
    ADC zp_sprite_height
    STA zp_sprite_end_index
    DEC zp_sprite_cols_remaining
    BNE sprite_plot_inner
    RTS
.L11D5
    DEX
.L11D6
    INY
    CPX #&FF
    BNE L11EF
    LDX zp_sprite_height
    DEX
    LDA sprite_src_lo
    CLC
    ADC #&20
    STA sprite_src_lo
    BNE L11BE
    INC sprite_src_hi
    JMP L11BE
.L11EF
    CPY #&08
    BNE sprite_plot_lda_sm
    LDA zp_screen_ptr_lo
    ADC #&3F
    STA zp_screen_ptr_lo
    LDA zp_screen_ptr_hi
    ADC #&01
    STA zp_screen_ptr_hi
    LDY #&00
    BEQ sprite_plot_lda_sm
.L1203
    INC sprite_src_hi
    JMP L11D6

\ ----- data &1209..&1236 -----
.screen_row_lo_lut
    \ Screen char-row low-byte LUT — MODE 5 with base &5800, stride &140 per char row
    EQUB &00, &40, &80, &C0, &00, &40, &80, &C0
    EQUB &00, &40, &80, &C0, &00, &40, &80, &C0
    EQUB &00, &40, &80, &C0, &00, &40
.screen_row_hi_lut
    \ Screen char-row high-byte LUT — pairs with screen_row_lo_lut
    EQUB &58, &59, &5A, &5B, &5D, &5E, &5F, &60
    EQUB &62, &63, &64, &65, &67, &68, &69, &6A
    EQUB &6C, &6D, &6E, &6F, &71, &72, &EA

\ ----- code &1236..&1307 -----
.calc_screen_addr
    \ Compute screen address from char-col X and caller-Y, store the result in zp_dest_x_lo/_hi
    \ ready for sprite_plot_xy. Caller-Y origin is at the BOTTOM of the screen — EOR #&FF inverts Y
    \ before the row LUT, so HIGHER caller-Y is HIGHER on screen. Same convention applies to all
    \ per-slot Y fields (hazard_y / enemy_y / pickup_y / flame_y / force_pod_y / player_y).
    \
    \ Inputs:
    \ X = char column (0..19 across the playfield)
    \ Y = scanline in caller-Y units (bottom = 0)
    \
    \ Outputs:
    \ zp_dest_x_lo / _hi = screen address for the top-left of the cell, ready to be consumed by
    \ sprite_plot_xy.
    \
    \ Clobbers: A.
    TYA
    EOR #&FF
    TAY
    AND #&07
    STA zp_dest_x_hi
    TYA
    LSR A
    LSR A
    LSR A
    TAY
    LDA screen_row_lo_lut,Y
    STA zp_dest_x_lo
    LDA zp_dest_x_hi
    CMP #&08
    BEQ L1252
    ADC zp_dest_x_lo
    STA zp_dest_x_lo
.L1252
    LDA screen_row_hi_lut,Y
    STA zp_dest_x_hi
    TXA
    BEQ L126B
    TAY
    CLC
.L125C
    LDA zp_dest_x_lo
    ADC #&08
    STA zp_dest_x_lo
    LDA zp_dest_x_hi
    ADC #&00
    STA zp_dest_x_hi
    DEY
    BNE L125C
.L126B
    RTS

.scroll_step
    \ Per-frame scroll entry. If zp_scroll_col has reached &F0 (the wrap point — last 240 columns of
    \ the map loop forever), restart the starfield and jump straight to update_hazards, skipping the
    \ scroll. Otherwise fall through to scroll_playfield.
    LDA zp_scroll_col
    CMP #&F0
    BNE scroll_playfield
    JSR starfield_init
    JMP update_hazards
    JMP update_hazards

.scroll_playfield
    \ Soft-scroll the playfield's upper and lower tile bands left by 8 pixels (one BBC char cell = 2
    \ byte-cols), then plot the new column at the right edge (col 39). The inner copy loop is
    \ unrolled into two parallel pairs of self-modified `LDA &XXXX / STA &XXXX` instructions — one
    \ pair for the upper band (HI = &58 → screen row 0), one for the lower band (HI = &6C → screen
    \ row 16). The eight self-modified operand bytes are named
    \ `scroll_{upper,lower}_{src,dst}_{lo,hi}` and are incremented in tandem by the loop. Outer
    \ counter X=5 + inner loop runs 256 iterations each ⇒ 5×256 = 1280 bytes per band copied (= 4
    \ char rows × 320 B/row, the full band). On exit, plot the freshly-scrolled-in column at (col
    \ &27, row 0) mirrored from zp_tile_upper, then (col &27, row 16) normal from zp_tile_lower.
    JSR starfield_update
    JSR update_hazards
    JSR get_ready_overlay
    LDX #&27
    LDY #&FF
    JSR calc_screen_addr
    LDA #&00
    STA scroll_upper_dst_lo
    STA scroll_lower_dst_lo
    STA zp_sprite_dir_flag
    LDA zp_tile_upper_lo
    STA sprite_src_lo
    CLC
    ADC #&20
    STA zp_tile_upper_lo
    LDA zp_tile_upper_hi
    STA sprite_src_hi
    LDA #&58
    STA scroll_upper_src_hi
    STA scroll_upper_dst_hi
    LDA #&6C
    STA scroll_lower_src_hi
    STA scroll_lower_dst_hi
    LDX #&05
    LDA #&08
    STA scroll_lower_src_lo
    STA scroll_upper_src_lo

.scroll_inner_loop
scroll_lower_src_lo = * + 1
scroll_lower_src_hi = * + 2
    \ Inner body of scroll_playfield's copy loop. The four `LDA &FFFF / STA &FFFF` instructions use
    \ the literal &FFFF only as a placeholder — at runtime each instruction's operand bytes (the
    \ `scroll_{upper,lower}_{src,dst}_{lo,hi}` equates defined immediately above each LDA/STA via `*
    \ + 1` / `* + 2`) have been pre-set to a real screen address, then INC'd at the bottom of the
    \ loop. Each iteration's `LDA` reads one byte further right and the matching `STA` writes one
    \ byte further left, sliding the band leftward.
    LDA &FFFF
scroll_lower_dst_lo = * + 1
scroll_lower_dst_hi = * + 2
    STA &FFFF
scroll_upper_src_lo = * + 1
scroll_upper_src_hi = * + 2
    LDA &FFFF
scroll_upper_dst_lo = * + 1
scroll_upper_dst_hi = * + 2
    STA &FFFF
    INC scroll_lower_src_lo
    INC scroll_upper_src_lo
    BNE scroll_inner_advance
    INC scroll_lower_src_hi
    INC scroll_upper_src_hi

.scroll_inner_advance
    INC scroll_lower_dst_lo
    INC scroll_upper_dst_lo
    BNE scroll_inner_loop
    INC scroll_lower_dst_hi
    INC scroll_upper_dst_hi
    DEX
    BNE scroll_inner_loop
    JSR sprite_plot_default
    LDX #&27
    LDY #&7F
    JSR calc_screen_addr
    INC zp_sprite_dir_flag
    LDA zp_tile_lower_lo
    STA sprite_src_lo
    CLC
    ADC #&20
    STA zp_tile_lower_lo
    LDA zp_tile_lower_hi
    STA sprite_src_hi
    JMP sprite_plot_default

\ ----- data &1307..&1309 -----
.starfield_slow_phase
    EQUB &10
.starfield_fast_phase
    EQUB &01

\ ----- code &1309..&14D8 -----
.starfield_update
    \ Per-frame starfield update — animates 60 stars in two parallel layers. The stars share three
    \ 60-entry arrays at &3041..&30F7 (starfield_pos_lo / _hi / _type), seeded by starfield_init at
    \ game start.
    \
    \ Two phase counters drive the animation; both are stepped once per call:
    \ starfield_slow_phase = LDA / EOR #&50 / STA — toggles bit 4 + bit 6
    \ starfield_fast_phase = ASL — shift left, so it cycles &01, &02, &04, &08, &10, then wraps back
    \ to 1
    \
    \ Then iterates X = 0..&3B over the 60 stars. Two layers, split by starfield_type[X]:
    \ type == 2 → slow layer. Erases the current pos with byte 0; if starfield_slow_phase == &10 (=
    \ every 16th frame), DECs the column pos by &08 (= 1 char-col left), wrapping &5C → &6B at the
    \ screen-RAM edge; re-plots as a single pixel of brightness &10.
    \ type != 2 → fast layer. Erases / re-plots at the current pos using the current
    \ starfield_fast_phase value as the pixel byte — so the star cycles through brightness levels 1,
    \ 2, 4, 8, &10 across frames (giving a twinkling effect). On the wrap-back (phase == &01), also
    \ DECs the column pos by &08 with the same screen-edge wrap, so fast stars scroll leftward one
    \ char-col every 5 frames.
    \
    \ Net effect: a 2-layer parallax starfield. Background stars (type 2) scroll slowly + plot a
    \ steady dim pixel. Foreground stars (other types) scroll faster + twinkle by cycling
    \ brightness. Both layers wrap horizontally inside the screen-RAM range &5C00..&6B00 (= the
    \ 12-row playfield gap between the upper and lower tile bands).
    \
    \ Inputs:
    \ starfield_pos_lo / _hi / _type (parallel arrays of 60)
    \ starfield_slow_phase, starfield_fast_phase (engine-state phase counters)
    \
    \ Effects: writes 60 screen bytes (erase + re-plot per star); mutates starfield_pos_lo / _hi
    \ (when columns advance); updates the phase counters.
    SEC
    LDY #&00
    LDX #&00
    LDA starfield_slow_phase
    EOR #&50
    STA starfield_slow_phase
    ASL starfield_fast_phase
.L1319
    LDA starfield_type,X
    CMP #&02
    BNE L136C
    LDA starfield_pos_lo,X
    STA zp_screen_ptr_lo
    LDA starfield_pos_hi,X
    STA zp_screen_ptr_hi
    LDA starfield_slow_phase
    CMP #&10
    BNE L133B
    LDA #&40
    STA (zp_screen_ptr_lo),Y
.L1335
    INX
    CPX #&3C
    BNE L1319
    RTS
.L133B
    LDA #&00
    STA (zp_screen_ptr_lo),Y
    LDA zp_screen_ptr_lo
    SBC #&08
    STA starfield_pos_lo,X
    CMP #&F8
    BNE L135B
    LDA starfield_pos_hi,X
    SBC #&01
    STA starfield_pos_hi,X
    CMP #&5C
    BNE L135B
    LDA #&6B
    STA starfield_pos_hi,X
.L135B
    LDA starfield_pos_lo,X
    STA zp_screen_ptr_lo
    LDA starfield_pos_hi,X
    STA zp_screen_ptr_hi
    LDA #&10
    STA (zp_screen_ptr_lo),Y
    JMP L1335
.L136C
    LDA starfield_pos_lo,X
    STA zp_screen_ptr_lo
    LDA starfield_pos_hi,X
    STA zp_screen_ptr_hi
    LDA starfield_fast_phase
    CMP #&10
    BNE L1382
    LDA #&01
    STA starfield_fast_phase
.L1382
    CMP #&01
    BNE L13B7
    LDA #&00
    STA (zp_screen_ptr_lo),Y
    LDA zp_screen_ptr_lo
    SBC #&08
    STA starfield_pos_lo,X
    CMP #&F8
    BNE L13A6
    LDA starfield_pos_hi,X
    SBC #&01
    STA starfield_pos_hi,X
    CMP #&5C
    BNE L13A6
    LDA #&6B
    STA starfield_pos_hi,X
.L13A6
    LDA starfield_pos_lo,X
    STA zp_screen_ptr_lo
    LDA starfield_pos_hi,X
    STA zp_screen_ptr_hi
    LDA #&01
    STA (zp_screen_ptr_lo),Y
    JMP L1335
.L13B7
    STA (zp_screen_ptr_lo),Y
    JMP L1335

.frame_delay
    \ Frame-rate regulator (busy-wait). Called once per main_loop iteration. Holds total frame time
    \ roughly constant by waiting (256 − work_done) outer iterations × 256 cycles inner. Heavy
    \ frames get shorter waits; idle frames get longer waits.
    \
    \ Inputs:
    \ zp_frame_progress = work-done counter (bumped by update_bullets, get_ready_overlay etc.)
    \ zp_game_speed = user's Speed preference from options.BAS (`?&92 = 120 + S%*30`); BREAK cheat
    \ sets to 252.
    \
    \ Outputs: zp_frame_progress reset to zp_game_speed for the next frame.
    \
    \ Overflow guard: `CPX #&64 / BCS / LDX #&FE` substitutes X=&FE if work-done wrapped past 255
    \ into a tiny value, preventing a paradoxically-long delay.
    LDX zp_frame_progress
    CPX #&64
    BCS L13C4
    LDX #&FE
.L13C4
    LDY #&00
.L13C6
    INY
    BNE L13C6
    INX
    BNE L13C4
    LDA zp_game_speed
    STA zp_frame_progress
    RTS

.game_step
    \ ONE TILE COLUMN of game progress. Called once per main_loop iteration.
    \
    \ Per-column setup (once per call):
    \ - try_spawn_pickup, spawn_periodic_enemy, spawn_check_step
    \ - resolve right-edge upper / lower tile pointers via tile_upper_ptr_calc / tile_lower_ptr_calc
    \ - INC zp_scroll_col (wraps &F0+ back to &F0 = end-of-map loop)
    \ - check PAUSE key
    \
    \ Then runs 4 sub-frames (the `play_subframe` loop, gated by `zp_get_ready_erase` 0→1→2→3→4).
    \ Each subframe scrolls the playfield by 4 px → 16 px per game_step call = one tile cell.
    \
    \ Per-subframe work: update_hazard_missiles → draw_score → force_pod_anim → frame_delay →
    \ update_enemies → scroll_step (which scrolls 4 px + calls update_hazards) → update_pickup →
    \ read_input. On even columns, also bumps zp_frame_progress and runs get_ready_overlay.
    \
    \ Returns early once `lives_left` reaches 0.
    JSR try_spawn_pickup
    JSR spawn_periodic_enemy
    JSR spawn_check_step
    LDX zp_scroll_col
    LDA lev_map_lower,X
    TAX
    INX
    LDA #&4E
    STA zp_tile_lower_hi
    LDA #&80
    STA zp_tile_lower_lo
    LDA #&00
    STA zp_dest_x_lo

.tile_lower_ptr_calc
    INC zp_dest_x_lo
    LDA zp_tile_lower_lo
    CLC
    ADC #&80
    STA zp_tile_lower_lo
    BNE tile_lower_ptr_advance
    INC zp_tile_lower_hi

.tile_lower_ptr_advance
    CPX zp_dest_x_lo
    BNE tile_lower_ptr_calc
    LDX zp_scroll_col
    LDA lev_map_upper,X
    TAX
    INX
    LDA #&4E
    STA zp_tile_upper_hi
    LDA #&80
    STA zp_tile_upper_lo
    LDA #&00
    STA zp_dest_x_lo

.tile_upper_ptr_calc
    INC zp_dest_x_lo
    LDA zp_tile_upper_lo
    CLC
    ADC #&80
    STA zp_tile_upper_lo
    BNE tile_upper_ptr_advance
    INC zp_tile_upper_hi

.tile_upper_ptr_advance
    CPX zp_dest_x_lo
    BNE tile_upper_ptr_calc
    INC zp_scroll_col
    LDA zp_scroll_col
    CMP #&F1
    BNE L142E
    LDA #&F0
    STA zp_scroll_col
.L142E
    LDX #KEY_PAUSE
    JSR check_key_pressed
    BNE L1438
    JSR pause_game
.L1438
    LDA #&00
    STA zp_get_ready_erase

.play_subframe
    \ Body of game_step's per-subframe inner loop. Runs once per BBC display frame (gated by
    \ frame_delay). 4 iterations are run per game_step (= per tile-column of horizontal scroll),
    \ producing the 4-frame soft-scroll animation between successive columns.
    LDA lives_left
    BEQ game_step_done
    JSR update_hazard_missiles
    JSR draw_score
    JSR force_pod_anim
    INC zp_get_ready_erase
    JSR frame_delay
    JSR update_enemies
    JSR scroll_step
    LDX #&00
    STX data_70FF
    INX
    STX zp_sprite_dir_flag
    JSR update_pickup
    JSR update_player_missiles
    JSR read_input
    LDA zp_scroll_col
    AND #&01
    BNE play_subframe_tail
    INC zp_frame_progress
    JSR get_ready_overlay

.play_subframe_tail
    LDA zp_get_ready_erase
    CMP #&04
    BCC play_subframe

.game_step_done
    RTS

.draw_player
    \ Draw the player ship and orbital pod, then check player collisions and update player bullets.
    \ Plots `lev_player_sprite` (6×22) at (zp_player_x, zp_player_y). If `pod_attached == 1`, also
    \ calls `draw_player_pod` at (player_x + 5, player_y + 1).
    \
    \ Inputs: zp_player_x / zp_player_y, pod_attached, pod_anim_frame.
    \
    \ Tail-calls: check_player_collisions, update_bullets (via JMP).
    LDX zp_player_x
    LDY zp_player_y
    JSR calc_screen_addr
    LDX #&06
    LDY #&16
    LDA #LO(lev_player_sprite)
    STA sprite_src_lo
    LDA #HI(lev_player_sprite)
    STA sprite_src_hi
    JSR sprite_plot_xy
    LDA pod_attached
    CMP #&01
    BNE L14AF
    LDA zp_player_x
    CLC
    ADC #&05
    TAX
    LDY zp_player_y
    INY
    JSR calc_screen_addr
    LDA #HI(gfx_pod_frame0)
    STA sprite_src_hi
    LDX #&04
    LDY #&18
    JSR draw_player_pod
.L14AF
    JSR check_player_collisions
    JMP update_bullets

.draw_player_pod
    \ Draw the player force-pod beside the ship. Selects one of three frames based on
    \ `pod_anim_frame`, sets sprite_src_lo to LO(gfx_pod_frame0 / _1 / _2), and falls through into
    \ sprite_plot_xy.
    \
    \ The HI byte is NOT set here — the caller (draw_player) has already done `LDA
    \ #HI(gfx_pod_frame0) / STA sprite_src_hi` just before the JSR. All three pod frames share the
    \ same HI page (&39), so the routine only has to vary the LO byte per frame.
    \
    \ Inputs:
    \ pod_anim_frame ∈ {1, 2, 3} — frame index
    \ X, Y = screen position (set up by caller's calc_screen_addr — typically (player_x + 5,
    \ player_y + 1))
    \ sprite_src_hi = HI(gfx_pod_frame0) (set by caller)
    \
    \ Dispatch table:
    \ pod_anim_frame == 1 → gfx_pod_frame0
    \ pod_anim_frame == 2 → gfx_pod_frame1
    \ else (= 3)          → gfx_pod_frame2
    \
    \ Note: pod_anim_frame is driven by vertical motion — move_player_up INCs it (wraps 4→1),
    \ move_player_down DECs (wraps 0→3). The else branch handles the value 3 directly.
    LDA pod_anim_frame
    CMP #&01
    BEQ L14C8
    CMP #&02
    BEQ L14D0
    LDA #LO(gfx_pod_frame2)
    STA sprite_src_lo
    JMP sprite_plot_xy
.L14C8
    LDA #LO(gfx_pod_frame0)
    STA sprite_src_lo
    JMP sprite_plot_xy
.L14D0
    LDA #LO(gfx_pod_frame1)
    STA sprite_src_lo
    JMP sprite_plot_xy

\ ----- data &14D8..&14D9 -----
.pod_anim_frame
    \ Force-pod animation frame index (1 / 2 / 3).
    \
    \ Drives which of gfx_pod_frame0 / _1 / _2 the draw_player_pod routine renders.
    \
    \ Stepped by player vertical motion — move_player_up INCs (wraps 4→1), move_player_down DECs
    \ (wraps 0→3).
    \
    \ Disk-initial value is 1.
    EQUB &01

\ ----- code &14D9..&156F -----
.read_input
    \ Per-frame input reader. If joystick mode (zp_9F == 1) takes the read_joystick path; otherwise
    \ scans the five keys KEY_RIGHT / KEY_LEFT / KEY_UP / KEY_DOWN / KEY_FIRE in turn via
    \ check_key_pressed and dispatches the matching move_player_* / on_fire_pressed routine for any
    \ that test pressed.
    \
    \ Inputs: zp_9F = control-mode flag.
    \
    \ Effects: may update zp_player_x / _y, install a player_bullet, or do nothing this frame.
    LDA zp_9F
    CMP #&01
    BEQ read_joystick
    LDX #KEY_RIGHT
    JSR check_key_pressed
    BNE L14EC
    JSR move_player_right
    JMP L14F6
.L14EC
    LDX #KEY_LEFT
    JSR check_key_pressed
    BNE L14F6
    JSR move_player_left
.L14F6
    LDX #KEY_UP
    JSR check_key_pressed
    BNE L1500
    JSR move_player_up
.L1500
    LDX #KEY_DOWN
    JSR check_key_pressed
    BNE L150A
    JSR move_player_down
.L150A
    LDX #KEY_FIRE
    JSR check_key_pressed
    BNE L1514
    JSR on_fire_pressed
.L1514
    JMP draw_player

.read_joystick
    \ Joystick input handler. OSBYTE &80 reads analog joystick 1 X/Y axes (thresholds &40 / &C8) and
    \ the fire-button bit, dispatching the same move_player_* / on_fire_pressed routines as the
    \ keyboard path. Threshold-based — pushing the stick past the deadzone moves one row/col.
    LDA #&80
    LDX #&01
    JSR OSBYTE
    CPY #&C8
    BCC L1528
    JSR move_player_left
    JMP L152F
.L1528
    CPY #&40
    BCS L152F
    JSR move_player_right
.L152F
    LDA #&80
    LDX #&02
    JSR OSBYTE
    CPY #&C8
    BCC L1540
    JSR move_player_up
    JMP L1547
.L1540
    CPY #&40
    BCS L1547
    JSR move_player_down
.L1547
    LDA #&80
    LDX #&00
    JSR OSBYTE
    TXA
    AND #&01
    CMP #&01
    BNE L1558
    JSR on_fire_pressed
.L1558
    JMP draw_player

.check_key_pressed
    \ Wraps OSBYTE &81 (= BASIC's `INKEY -X`) for a negative key-scan. Lets a caller test one
    \ specific scan code via a single JSR.
    \
    \ Inputs: X = key scan code (e.g. KEY_FIRE = &B6 corresponds to INKEY -74).
    \
    \ Outputs: Z flag set if key NOT pressed, clear if pressed. (Internally Y is forced to &FF for
    \ the OSBYTE protocol.) Callers use `BNE not_pressed` / `BEQ pressed`.
    \
    \ Clobbers: A, X, Y.
    LDA #&81
    LDY #&FF
    JSR OSBYTE
    CPY #&FF
    RTS

.move_player_left
    \ Move player one column LEFT (DEC zp_player_x, clamped at min &02).
    LDA zp_player_x
    CMP #&02
    BNE L156C
    RTS
.L156C
    DEC zp_player_x
    RTS

\ ----- data &156F..&1577 -----
\ Player-missile pool state: player_missile_x[2] + player_missile_y[2] + player_missile_frame (1 B)
\ + player_missile_step (1 B) + player_missile_active[2] (= 8 B covering &156F..&1576). All zero on
\ the disk; populated by fire_player_missiles when the tier-7 pickup unlocks the missiles. Tracer
\ would otherwise decode the zero bytes as BRK.
.player_missile_x
    EQUB &00, &00
.player_missile_y
    EQUB &00, &00
.player_missile_frame
    EQUB &00
.player_missile_step
    EQUB &00
.player_missile_active
    EQUB &EA, &EA

\ ----- code &1577..&16E6 -----
.fire_player_missiles
    \ Launch the paired player missile pair (upper + lower). Gated on `player_missiles_unlocked ==
    \ 1` (= the player has collected 7 pickups → tier 7) AND `player_missile_step == 0` (= no pair
    \ in flight).
    \
    \ On launch: captures the player position into both slots — upper (player_x, player_y + 2),
    \ lower (player_x, player_y - &12). Activates both slots, sets player_missile_frame = 1,
    \ player_missile_step = 1. The next-pass `update_player_missiles` then animates the pair.
    \
    \ Edge clamps: suppresses the upper missile if player_y >= &D8 (would be off-screen top);
    \ suppresses the lower if player_y < &A0 (would be off-screen bottom).
    LDA player_missiles_unlocked
    CMP #&01
    BEQ L157F
    RTS
.L157F
    LDA player_missile_step
    BEQ L1585
    RTS
.L1585
    LDX zp_player_x
    STX player_missile_x
    STX player_missile_x + 1
    LDA zp_player_y
    CLC
    ADC #&02
    STA player_missile_y
    SEC
    SBC #&14
    STA player_missile_y + 1
    LDA #&01
    STA player_missile_active
    STA player_missile_active + 1
    LDA #&01
    STA player_missile_frame
    LDA #&01
    STA player_missile_step
    LDA zp_player_y
    CMP #&D8
    BCS L15B8
    CMP #&A0
    BCC L15BE
    RTS
.L15B8
    LDA #&00
    STA player_missile_active
    RTS
.L15BE
    LDA #&00
    STA player_missile_active + 1
    RTS

.update_player_missiles
    \ Per-subframe ticker for the paired player missiles. RTS immediately if `player_missile_step ==
    \ 0` (idle).
    \
    \ Phase 0 (steps 1..4): vertical-spread — INC upper_y, DEC lower_y.
    \ Phase 1 (steps 5..7): walk pair rightward by +1 px, advance missile-frame (1→2→3→4→5→2
    \ ping-pong).
    \ Phase 2 (steps 8+): accelerate to +2 px/subframe.
    \
    \ Each subframe re-plots whichever slots are active via plot_player_missile. When
    \ player_missile_x[0] >= &24 (off the right edge), erases both sprites and resets state.
    \ Individual slots can also be cleared early by `missile_hit_hazard` when the missile connects.
    LDA player_missile_step
    BNE L15CA
    RTS
.L15CA
    LDA player_missile_step
    CMP #&05
    BCS L15DD
    INC player_missile_y
    DEC player_missile_y + 1
    INC player_missile_step
    JMP L160E
.L15DD
    INC player_missile_frame
    LDA player_missile_frame
    CMP #&06
    BNE L15EC
    LDA #&02
    STA player_missile_frame
.L15EC
    LDA player_missile_step
    CMP #&08
    BCS L15FF
    INC player_missile_x
    INC player_missile_x + 1
    INC player_missile_step
    JMP L160E
.L15FF
    INC player_missile_x
    INC player_missile_x
    INC player_missile_x + 1
    INC player_missile_x + 1
    INC player_missile_step
.L160E
    LDA #&01
    STA zp_sprite_dir_flag
    LDA player_missile_active
    CMP #&01
    BNE L1625
    LDX player_missile_x
    LDY player_missile_y
    JSR calc_screen_addr
    JSR plot_player_missile
.L1625
    LDA player_missile_active + 1
    CMP #&01
    BNE L1638
    LDX player_missile_x + 1
    LDY player_missile_y + 1
    JSR calc_screen_addr
    JSR plot_player_missile
.L1638
    LDA player_missile_x
    CMP #&24
    BCC L1688
    LDA player_missile_active
    BEQ L165E
    LDX player_missile_x
    LDY player_missile_y
    JSR calc_screen_addr
    LDX #&05
    LDY #&08
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    JSR sprite_plot_xy
.L165E
    LDA player_missile_active + 1
    BEQ L167D
    LDX player_missile_x
    LDY player_missile_y + 1
    JSR calc_screen_addr
    LDX #&05
    LDY #&08
    LDA #LO(lev_erase_brush + &80)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &80)
    STA sprite_src_hi
    JSR sprite_plot_xy
.L167D
    LDA #&00
    STA player_missile_x + 1
    STA player_missile_x
    STA player_missile_step
.L1688
    RTS

.plot_player_missile
    \ Plot one player-missile frame at the screen position already set up by the caller's
    \ `calc_screen_addr`.
    \
    \ The source sprite is selected by an inline multiply-by-&28 on player_missile_frame. The
    \ starting LO byte is `LO(gfx_missile_0)` (= 0), then the loop adds &28 once per frame index and
    \ the trailing SBC #&28 corrects for the off-by-one, yielding `LO(gfx_missile_(frame-1))`. HI is
    \ `HI(gfx_missile_0)` since all five frames live in the same page (&44).
    \
    \ Inputs:
    \ player_missile_frame ∈ [1, 5] — selects gfx_missile_0..gfx_missile_4
    \ zp_dest_x_lo / _hi = destination screen address (set by caller)
    \
    \ Plots a 5×8 px sprite via JMP sprite_plot_xy.
    LDA #LO(gfx_missile_0)
    LDX player_missile_frame
    CLC
.L168F
    ADC #&28
    DEX
    BNE L168F
    SEC
    SBC #&28
    STA sprite_src_lo
    LDA #HI(gfx_missile_0)
    STA sprite_src_hi
    LDX #&05
    LDY #&08
    JMP sprite_plot_xy

.move_player_right
    \ Move player one column RIGHT (INC zp_player_x, clamped at max &14).
    LDA zp_player_x
    CMP #&14
    BNE L16AD
    RTS
.L16AD
    INC zp_player_x
    RTS

.move_player_up
    \ Move player one row UP (zp_player_y += 4, clamped at max &DC). NOTE: caller-Y origin is at the
    \ BOTTOM of the screen — `calc_screen_addr` does an EOR #&FF before the row LUT, so HIGHER
    \ `zp_player_y` is HIGHER on screen. Also INCs `pod_anim_frame` (wraps 4→1).
    LDA zp_player_y
    CMP #&DC
    BNE L16B7
    RTS
.L16B7
    CLC
    ADC #&04
    STA zp_player_y
    INC pod_anim_frame
    LDA pod_anim_frame
    CMP #&04
    BNE L16CB
    LDA #&01
    STA pod_anim_frame
.L16CB
    RTS

.move_player_down
    \ Move player one row DOWN (zp_player_y -= 4, clamped at min &98). Also DECs `pod_anim_frame`
    \ (wraps 0→3). See `move_player_up` for the Y-origin note.
    LDA zp_player_y
    CMP #&98
    BNE L16D3
    RTS
.L16D3
    SEC
    SBC #&04
    STA zp_player_y
    DEC pod_anim_frame
    LDA pod_anim_frame
    BNE L16E5
    LDA #&03
    STA pod_anim_frame
.L16E5
    RTS

\ ----- data &16E6..&1712 -----
.player_bullet_x
    EQUB &00, &00, &00, &00, &00, &00, &00
.player_bullet_y
    EQUB &00, &00, &00, &00, &00, &00, &00, &EA
.data_16F5
    EQUB &EA
.data_16F6
    EQUB &EA
.data_16F7
    EQUB &EA
.data_16F8
    EQUB &EA, &EA, &EA
.enemy_pattern_ptr_lo
    EQUB &EA
    EQUB LO(enemy_pattern_1)
    EQUB LO(enemy_pattern_2)
    EQUB LO(enemy_pattern_3)
    EQUB LO(enemy_pattern_4)
    EQUB &EA, &EA
.enemy_pattern_ptr_hi
    EQUB &EA
    EQUB HI(enemy_pattern_1)
    EQUB HI(enemy_pattern_2)
    EQUB HI(enemy_pattern_3)
    EQUB HI(enemy_pattern_4)
    EQUB &EA, &EA
.enemy_pattern_len_lut
    EQUB &EA
    EQUB enemy_pattern_1_end - enemy_pattern_1
    EQUB enemy_pattern_2_end - enemy_pattern_2
    EQUB enemy_pattern_3_end - enemy_pattern_3
    EQUB enemy_pattern_4_end - enemy_pattern_4
    EQUB &EA, &EA
.enemy_pattern_len
    EQUB &EA, &EA

\ ----- code &1712..&1A55 -----
.spawn_periodic_enemy
    \ Periodic background-enemy spawner. Called once per game_step. Doesn't run after the map has
    \ wrapped (zp_scroll_col == &F0). Otherwise paces on zp_87 (sub-counter, 0..A): when zp_87
    \ reaches &0A, waits for the enemy field to fully empty, then advances `zp_86` (pattern
    \ selector, cycles 1..6 wrapping back to 1) and pre-loads the per-pattern parameters:
    \ enemy_pattern_ptr_lo[zp_86] → zp_88   (script ptr LO)
    \ enemy_pattern_ptr_hi[zp_86] → zp_89   (script ptr HI)
    \ enemy_pattern_len_lut[zp_86] → enemy_pattern_len   (script wrap-around byte count)
    \ The four valid scripts (idx 1..4) live at &4500 / &4574 / &4614 / &4680 inside the GRAPHIX
    \ region — sequences of (dy_dir, dx_dir) byte pairs that L1B87 walks per enemy slot to drive
    \ motion.
    \
    \ On the other 10 calls of each cycle: INCs zp_87 and spawns one enemy into the first free slot
    \ — enemy_x = &25 (right edge); enemy_state / enemy_y set per pattern (patterns 5/6: state 3/5,
    \ Y random in [&97..&D7]; others: state 1, Y = &9A fixed).
    LDA zp_scroll_col
    CMP #&F0
    BNE L1719
    RTS
.L1719
    LDA zp_87
    CMP #&0A
    BNE L1753
    LDX #&08
.L1721
    LDA enemy_state,X
    BNE L1752
    DEX
    BNE L1721
    INC zp_86
    LDA zp_86
    CMP #&05
    BEQ L17A5
    CMP #&06
    BEQ L17AF
    CMP #&07
    BNE L173D
    LDA #&01
    STA zp_86
.L173D
    TAX
    LDA enemy_pattern_len_lut,X
    STA enemy_pattern_len
    LDA enemy_pattern_ptr_lo,X
    STA zp_88
    LDA enemy_pattern_ptr_hi,X
    STA zp_89
    LDA #&00
    STA zp_87
.L1752
    RTS
.L1753
    INC zp_87
    LDX #&08
.L1757
    LDA enemy_state,X
    BEQ L175F
    DEX
    BNE L1757
.L175F
    LDA #&25
    STA enemy_x,X
    LDA #&00
    STA enemy_pattern_step,X
    LDA zp_86
    STA enemy_pattern_id,X
    CMP #&05
    BEQ L1781
    CMP #&06
    BEQ L1793
    LDA #&01
    STA enemy_state,X
    LDA #&9A
    STA enemy_y,X
    RTS
.L1781
    LDA #&03
    STA enemy_state,X
    JSR lfsr_random
    SEC
    LDA #&D7
    SBC rndval64
    STA enemy_y,X
    RTS
.L1793
    LDA #&05
    STA enemy_state,X
    JSR lfsr_random
    SEC
    LDA #&D7
    SBC rndval64
    STA enemy_y,X
    RTS
.L17A5
    LDA #&26
    STA enemy_pattern_len
    LDA #&00
    STA zp_87
    RTS
.L17AF
    LDA #&26
    STA enemy_pattern_len
    LDA #&00
    STA zp_87
    RTS

.on_fire_pressed
    \ Fire-button handler — called from read_input on KEY_FIRE pressed. Refuses if the per-frame
    \ cooldown counter (zp_8A) is non-zero. On accept: finds the first empty slot in
    \ player_bullet_x[4..1] (the keyboard-fire range — slots 5..6 are reserved for the force-pod's
    \ twin-shot, populated by `pod_fire` in CODE2), installs a new bullet at (player_x + 2, player_y
    \ - &0C), reloads the cooldown, and plays sfx_fire.
    \
    \ Inputs: zp_player_x / _y, zp_8A (cooldown), fire_cooldown_reload (default 6 frames; drops to 3
    \ after the 1st pickup).
    \
    \ Effects: installs one player_bullet slot if free; resets zp_8A; plays sfx_fire.
    JSR fire_player_missiles
    LDA zp_8A
    BEQ L17C1
    RTS
.L17C1
    LDX #n_player_fire_slots
.L17C3
    LDA player_bullet_x,X
    BEQ L17CC
    DEX
    BNE L17C3
    RTS
.L17CC
    LDA zp_player_x
    CLC
    ADC #&02
    STA player_bullet_x,X
    LDA zp_player_y
    SEC
    SBC #&0C
    STA player_bullet_y,X
    LDA fire_cooldown_reload
    STA zp_8A
    JSR sfx_fire
    JMP pod_fire

.update_bullets
    \ Per-frame mover for the 6-slot player_bullet pool. Iterates X = n_player_bullets..1 (predec);
    \ for each active slot (player_bullet_x[X] != 0):
    \ - DEC slot (move 2 px right)
    \ - if past col &25, ERASE (plot 2×2 from lev_erase_brush + &102) and clear slot
    \ - else RE-PLOT via a 3×2 read from `lev_erase_brush + &102`: two zero-pad cols leading + the
    \ visible 4×2 `player_bullet_sprite` byte at col 2 — palette-2 colour: yellow / cyan / green /
    \ magenta per scenario. The leading zero pad over-paints the previous frame's visible col →
    \ built-in trail erase.
    \ - then check_bullet_hits.
    \
    \ Finally DECs zp_8A (fire cooldown) on the way out.
    LDX #n_player_bullets
.L17E9
    LDA player_bullet_x,X
    BEQ L183D
    LDY player_bullet_y,X
    INC player_bullet_x,X
    INC player_bullet_x,X
    LDA player_bullet_x,X
    STX data_16F5
    TAX
    CPX #&25
    BCC L1824
    JSR calc_screen_addr
    LDX data_16F5
    LDA #&00
    STA player_bullet_x,X
    LDX #&02
    LDY #&02
    LDA #LO(lev_erase_brush + &102)
    STA sprite_src_lo
    LDA #HI(lev_erase_brush + &102)
    STA sprite_src_hi
    JSR sprite_plot_xy
    LDX data_16F5
    JMP L183D
.L1824
    JSR calc_screen_addr
    LDX #&03
    LDY #&02
    TYA
    STA sprite_src_lo
    LDA #HI(player_bullet_sprite - &4)
    STA sprite_src_hi
    JSR sprite_plot_xy
    JSR check_bullet_hits
    LDX data_16F5
.L183D
    DEX
    BNE L17E9
    LDA zp_8A
    BEQ L1846
    DEC zp_8A
.L1846
    RTS

.check_bullet_hits
    \ Check what the current player bullet has hit. The caller (update_bullets) has just moved the
    \ bullet; this routine tests it against both NPC pools.
    \
    \ Two loops over the same bullet position (zp_test_x = player_bullet_x[X] + 2, zp_test_y =
    \ player_bullet_y[X]):
    \ (a) X = 8..1 over the enemy slots in enemy_x / _y / enemy_state — a hit INCs enemy_state[X];
    \ at values 3/5/7 plays OSWRCH 7 + INCs pickup_kill_count; at >= 9 the enemy is fully expired.
    \ (b) X = 0..7 over the hazard slots in hazard_x / _y / hazard_type — a hit DECs hazard_hp; on
    \ kill, mutates hazard_type to &14 to start the death animation.
    \
    \ On either hit: the bullet erases itself (3×2 brush) and the slot is freed.
    LDX data_16F5
    LDY player_bullet_x,X
    INY
    INY
    STY zp_test_x
    LDA player_bullet_y,X
    STA zp_test_y
